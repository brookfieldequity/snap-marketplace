{
  "expo": {
    "name": "SNAP",
    "slug": "snap-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "snap",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapmedical.marketplace",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Used to center the shift map near you and sort shifts by distance.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.724134958485-teqsmte78bbruief2npp1b9ds3039pgg"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#123B6B"
      },
      "package": "com.snapmedical.marketplace",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "9de4ba24-a1a2-429e-b04c-1147b9d53171"
      }
    },
    "owner": "brookfieldequity",
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-notifications"
    ]
  }
}
