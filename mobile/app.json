{
  "expo": {
    "name": "SNAP",
    "slug": "snap-marketplace",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "snap",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapmedical.marketplace",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Used to center the shift map near you and sort shifts by distance."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366F1"
      },
      "package": "com.snapmedical.marketplace",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "9de4ba24-a1a2-429e-b04c-1147b9d53171"
      }
    },
    "owner": "brookfieldequity",
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
