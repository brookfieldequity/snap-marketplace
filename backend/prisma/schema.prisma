  source          String             @default("calculator")
  facilityName    String?
  contactName     String?
  email           String
  calculatorType  CalculatorType?
  savingsEstimate Float?
  reportSentAt    DateTime?
  followUpStatus  LeadFollowUpStatus @default(NEW)
