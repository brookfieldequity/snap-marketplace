model StaffIQInput {
  id                              String   @id @default(cuid())
  facilityId                      String
  facility                        Facility @relation(fields: [facilityId], references: [id])
  totalLocations                  Int
  avgRoomsPerDay                  Float
  ftAnesthesiologists             Int
  ftCrnas                         Int
  pdAnesthesiologistsPerMonth     Int
  pdCrnasPerMonth                 Int
  agencyAnesthesiologistsPerMonth Int
  agencyCrnasPerMonth             Int
  // What an agency actually bills this facility per hour (coordinator-entered).
  // Null = not entered; savings math falls back to network priors ($425/$300/$250)
  // and labels the resulting figure "estimated".
  agencyAnesthesiologistRate      Float?
  agencyCrnaRate                  Float?
  agencyAaRate                    Float?
  avgAnesthesiologistRate         Float
  avgCrnaRate                     Float
  avgShiftHours                   Float    @default(10)
  operatingDaysPerYear            Int      @default(250)
  primaryTeamModel                String
  staffiqScore                    Int
  inefficiency1Pct                Float
  inefficiency2Pct                Float
  inefficiency1Cost               Float
  inefficiency2Cost               Float
  totalBudget                     Float
