// ─────────────────────────────────────────────────────────────────────────────
// SNAP Shifts — Coverage Templates
//
// Per-practice templates capturing standard staffing patterns (locations ×
// day-of-week × room count). Used to bulk-materialize ScheduleDay rows when
// a coordinator generates a new month's schedule. See
// docs/coverage-templates-design.md for the full design (incl. v1.1 plans
// for per-site coverage rules that feed StaffIQ).
// ─────────────────────────────────────────────────────────────────────────────

model CoverageTemplate {
  id         String                @id @default(cuid())
  facilityId String
  facility   Facility              @relation(fields: [facilityId], references: [id])
  name       String // e.g. "Standard Week", "Summer Schedule"
  isDefault  Boolean               @default(false) // practice's default pick
  days       CoverageTemplateDay[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([facilityId, name])
  @@index([facilityId, isDefault])
}

model CoverageTemplateDay {
  id            String           @id @default(cuid())
  templateId    String
  template      CoverageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  location      String // free text — matches ScheduleDay.location string semantics
  dayOfWeek     Int // 0=Sunday … 6=Saturday
  roomsRequired Int              @default(1)

  // Default shift window for this location on this weekday, "HH:MM" 24h
  // (e.g. "06:30" / "15:30"). Pre-fills provider hour-entry so a 1099 only has
  // to adjust exceptions; null = no default set. See provider hour-entry feature.
  defaultStartTime String?
  defaultEndTime   String?

  // Anesthesia care-team model. null = MD-only (every room a solo
  // anesthesiologist). 3 = team 1:3, 4 = team 1:4 (rooms staffed by CRNAs,
  // supervised by anesthesiologists at this ratio). Stored per location-day
  // so a site can be team model on weekdays, MD-only on weekends. The
  // builder's supervision-assignment logic consumes this (Task #21).
  supervisionRatio Int?

  @@unique([templateId, location, dayOfWeek])
}

enum HolidaySource {
  PRACTICE_ADDED // practice-defined holiday in addition to federal calendar
  PRACTICE_EXCLUDED // practice opted out of a normally-federal holiday
}

model FacilityHoliday {
  id         String        @id @default(cuid())
  facilityId String
  facility   Facility      @relation(fields: [facilityId], references: [id])
  date       DateTime      @db.Date
  label      String
  source     HolidaySource

  @@unique([facilityId, date])
  @@index([facilityId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// SNAP Shifts — Schedule Builder v2
//
// Stores each "Build the Schedule" attempt so the coordinator can compare
// candidates side-by-side, and so we accumulate the data StaffIQ learns
// from over time. See docs/schedule-builder-v2-design.md.
// ─────────────────────────────────────────────────────────────────────────────

enum BuildMode {
  COST_EFFICIENT
  HIGHEST_QUALITY
  HYBRID
  STAFFIQ
}

enum BuildRunStatus {
  RUNNING
  COMPLETE
  FAILED
  SUPERSEDED // newer run for the same month replaced this one
}

model ScheduleBuildRun {
  id           String         @id @default(cuid())
  facilityId   String
  facility     Facility       @relation(fields: [facilityId], references: [id])
  year         Int
  month        Int // 1-12
  buildBatchId String // groups multi-mode runs triggered together
  mode         BuildMode
  status       BuildRunStatus

  // Snapshot of input state — enough to reproduce + explain the run later.
  // Includes ScheduleDay rows + the roster + availability + holidays.
  inputSnapshot Json

  // Output: array of { scheduleDayId, roomNumber, rosterId } objects.
  // Stored as JSON so we can compare 4 candidates without writing to
  // ScheduleAssignment until the coordinator selects one.
  assignments Json

  staffiqScore Int? // 0-100, null while RUNNING or FAILED
  insights     Json? // { totalCost, locumsUsed, avgSeniority, ... }
  warnings     String[] // human-readable: "Could not staff Kenmore Mon 8/4"

  // StaffIQ CRNA-gap recommendations (Task #26): { gaps: [...], total... }.
  // Each gap = a team-location-day where CRNAs were short and MDs backfilled,
  // with the dollar penalty + the savings from incentivizing CRNAs.
  staffiqRecommendations Json?

  // Per-request honored/not-honored report for this run's assignments. Array of
  // { requestId, providerName, type, date, siteName, tier, honored, reason }.
  // Lets the coordinator see which provider requests this candidate satisfied
  // before committing it. Computed per mode (each run's assignments differ).
  requestOutcomes Json?

  selectedAt        DateTime? // when coordinator picked this run as active
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  triggeredByUserId String
  triggeredByUser   User      @relation(fields: [triggeredByUserId], references: [id])

  @@index([facilityId, year, month, buildBatchId])
  @@index([facilityId, selectedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Automation events — time-saved tracking for the "Cost Savings" widget on
// the marketplace facility credentialing portal + SNAP Shifts dashboard + the
// SNAP admin aggregate page. One row per discrete automation action that
// would have otherwise taken coordinator/SNAP-team time. Minutes-saved is
// fixed per event type (services/automationEvents.js MINUTES_BY_TYPE) so the
// totals are predictable and not based on per-event guesses.
//
// facilityId nullable for SNAP-level events that don't belong to a facility
// (rare for v1; mostly populated). Aggregating across all rows yields the
// SNAP admin "total impact" number.
//
// $50/hour conversion happens at read time in the helper — not stored — so
// the rate can be retuned later without a schema migration.
// ─────────────────────────────────────────────────────────────────────────────

model AutomationEvent {
  id           String              @id @default(cuid())
  facilityId   String?
  facility     Facility?           @relation(fields: [facilityId], references: [id])
  type         AutomationEventType
  minutesSaved Int
  metadata     Json?
  eventAt      DateTime            @default(now())

  @@index([facilityId, eventAt])
  @@index([type, eventAt])
}

enum AutomationEventType {
  // Marketplace + SNAP Shifts (high-time-saving coordinator-replacing flows)
  ROSTER_UPLOAD // 180 min — bulk roster CSV/Excel ingestion
  COVERAGE_TEMPLATE_GENERATE // 120 min — month-of-schedule from a template
  SCHEDULE_BUILD_RUN // 240 min — Schedule Builder v2 4-mode build

  // Credentialing portal (lower per-event, higher frequency)
  SIGNATURE_REQUEST_SENT // 45 min  — coordinator fires a sig request
  PASSPORT_GRANT_REQUEST // 30 min  — coordinator fires a grant request

  // Future (wire when feature ships):
  //   NPPES_AUTOFILL        // 30 min per credential
  //   SEALED_PDF_SNAPSHOT   // 60 min — coordinator skips manual file assembly
  //   FORM_READER           // 60 min — external hospital form auto-fill
}

// ── Provider notification inbox (Task #16) ─────────────────────────────────────
// Durable per-provider record of every alert. Push remains the wake-up channel;
// this is the inbox the provider opens to see what happened. Written everywhere
// we currently fire a push/SMS (schedule published, shift offered, request
// answered, etc.). Read on the provider mobile home screen with an unread badge.
model Notification {
  id         String          @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  // Coarse category drives the icon + tap target on the client.
  type       String // SCHEDULE_PUBLISHED | SHIFT_OFFERED | REQUEST_ANSWERED | GENERAL | ...
  title      String
  body       String
  // Optional structured payload for deep-linking (shiftId, date, facilityId…).
  data       Json?
  readAt     DateTime?
  createdAt  DateTime        @default(now())

  @@index([providerId, createdAt])
  @@index([providerId, readAt])
}

// ── Provider schedule requests (Task #21) ──────────────────────────────────────
// A provider asks the coordinator for something about a specific date — a day
// off, or to work a particular date/site. The coordinator accepts or declines;
// accepted requests become constraints the schedule builder honors (hard
// exclude for DAY_OFF, strong preference for WORK). Mirrors RosterTimeOff's
// facility+roster scoping so the builder can join on rosterId.
model ScheduleRequest {
  id            String              @id @default(cuid())
  facilityId    String
  facility      Facility            @relation(fields: [facilityId], references: [id])
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  // DAY_OFF = don't schedule me this date. WORK = please schedule me this date.
  // PTO = paid time off (counts against the provider's annual allotment); on
  // accept it writes source='PTO' RosterAvailability rows across [date,endDate].
  type          String // "DAY_OFF" | "WORK" | "PTO"
  date          DateTime            @db.Date
  // Inclusive end of the request span. null = single-day (date only). Used by
  // PTO requests so a provider can request e.g. a Mon–Fri week in one request.
  endDate       DateTime?           @db.Date
  // For WORK requests, the site the provider wants (optional; null = any site).
  siteName      String?
  note          String?
  status        String              @default("PENDING") // PENDING | ACCEPTED | DECLINED
  // Priority tier the admin assigns when triaging an ACCEPTED request, used by
  // the schedule builder. WORK + DAY_OFF only (PTO uses the PTO Builder).
  //   1 = Locked   — honor unless literally impossible to cover the room.
  //   2 = Strong   — honor if at all possible (break only to avoid OT/agency
  //                  cost or an uncovered room). Default for legacy accepts.
  //   3 = Moderate — honor only if it doesn't meaningfully disrupt the schedule.
  //   4 = Loose    — honor only if it costs nothing (a free slot already exists).
  // null until triaged. A Tier-1 DAY_OFF materializes a RosterTimeOff (hard
  // exclude); tiers 2–4 stay soft and are weighted by the builder.
  tier          Int?
  // Admin's manual position WITHIN a tier (0-based; lower wins ties). null =
  // use the auto seed (seniority → first-come). Set when the admin reorders.
  manualOrder   Int?
  decidedAt     DateTime?
  decidedBy     String?
  createdAt     DateTime            @default(now())

  @@index([facilityId, status])
  @@index([rosterEntryId, date])
  @@index([facilityId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// PTO Builder (Feature B) — annual ranked PTO bidding. See pto-builder-spec.
//
// Flow: admin opens a PtoWindow for a year (open/close dates). Eligible
// providers rank up to maxRanks PTO weeks (Mon–Sun) via a signed web link
// (PtoBid rows). At close the admin runs allocation: tier-by-tier by rank,
// seniority tie-break, capped by each week's capacity AND each provider's
// remaining annual allotment. Results land in PtoAllocation (GRANTED /
// WAITLISTED); granted weeks also write source='PTO' RosterAvailability rows
// so they hit the calendar + schedule builder, and count via services/pto.js.
// ─────────────────────────────────────────────────────────────────────────────

model PtoWindow {
  id                    String   @id @default(cuid())
  facilityId            String
  facility              Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  year                  Int
  openDate              DateTime @db.Date
  closeDate             DateTime @db.Date
  // Global per-week capacity default (how many providers may have PTO that
  // week). Per-week overrides live in PtoWeekCapacity. Per-role/per-site
  // capacity is deferred — PtoWeekCapacity is shaped to grow into it.
  defaultWeeklyCapacity Int      @default(1)
  // How many weeks each provider may rank (1 = most wanted … maxRanks).
  maxRanks              Int      @default(15)
  status                String   @default("DRAFT") // DRAFT | OPEN | CLOSED | ALLOCATED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  capacities  PtoWeekCapacity[]
  bids        PtoBid[]
  allocations PtoAllocation[]

  @@unique([facilityId, year])
}

// Per-week capacity override for a window. Absent row → window.defaultWeeklyCapacity.
// `mode` is GLOBAL for this build; role/site columns are reserved for the
// deferred per-role / per-site capacity without a future migration churn.
model PtoWeekCapacity {
  id        String    @id @default(cuid())
  windowId  String
  window    PtoWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)
  weekStart DateTime  @db.Date // Monday of the week
  capacity  Int
  mode      String    @default("GLOBAL") // GLOBAL (reserved: ROLE | SITE)
  role      String? // reserved for per-role capacity
  siteName  String? // reserved for per-site capacity

  @@unique([windowId, weekStart, mode, role, siteName])
  @@index([windowId, weekStart])
}

// One provider's ranking of one week within a window. rank is 1-based
// (1 = most wanted). A provider uses each rank at most once and each week once.
model PtoBid {
  id            String              @id @default(cuid())
  windowId      String
  window        PtoWindow           @relation(fields: [windowId], references: [id], onDelete: Cascade)
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  weekStart     DateTime            @db.Date // Monday of the ranked week
  rank          Int
  createdAt     DateTime            @default(now())

  @@unique([windowId, rosterEntryId, weekStart])
  @@unique([windowId, rosterEntryId, rank])
  @@index([windowId, weekStart])
}

// Allocation result for a (provider, week) after the engine runs. GRANTED
// rows also materialize source='PTO' RosterAvailability rows for the week's
// weekdays. WAITLISTED rows carry a rank-ordered waitlistPos for auto-promote.
model PtoAllocation {
  id            String              @id @default(cuid())
  windowId      String
  window        PtoWindow           @relation(fields: [windowId], references: [id], onDelete: Cascade)
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  weekStart     DateTime            @db.Date
  rank          Int // the rank this provider gave this week
  status        String // GRANTED | WAITLISTED
  waitlistPos   Int? // 1-based position among waitlisted for this week (null when granted)
  decidedAt     DateTime            @default(now())

  @@unique([windowId, rosterEntryId, weekStart])
  @@index([windowId, weekStart, status])
}

// ── Admin scorecard (EOS weekly scorecard) — see docs/admin-scorecard-spec.md ──
// Manual inputs for the numbers the platform can't auto-compute yet: MRR (until
// Stripe billing exists), pipeline + days-to-close (until HubSpot is wired), and
// CAPA NPS (until a survey mechanism exists). Single upserted row (id="singleton").
model ScorecardManual {
  id             String   @id @default("singleton")
  mrrMonthly     Float? // manual MRR override (until billing)
  pipelineActive Int? // active sales conversations (HubSpot/manual)
  avgDaysToClose Float? // avg days to close open deals
  capaNps        Float? // CAPA administrator NPS (1-10)
  updatedBy      String?
  updatedAt      DateTime @updatedAt
}

// Weekly snapshot of the seven numbers — powers trend lines + the weekly report.
model ScorecardSnapshot {
  id                  String   @id @default(cuid())
  weekOf              DateTime
  activeProviders     Int      @default(0)
  shiftsCompletedCum  Int      @default(0)
  shiftsCompletedWeek Int      @default(0)
  pipelineActive      Int?
  avgDaysToClose      Float?
  mrr                 Float?
  capaBackupReduction Float? // percent
  capaNps             Float?
  createdAt           DateTime @default(now())

  @@index([weekOf])
}

// ══════════════════════════════════════════════════════════════════════════════
// Feature flags + Payroll Builder (added 2026-06-18)
// ══════════════════════════════════════════════════════════════════════════════

// Per-facility feature gate. Effective access for a flag = this row's `enabled`
// if a row exists (an explicit SNAP-admin override), otherwise the default for
// the facility's SubscriptionTier (see config/featureFlags.js TIER_DEFAULTS).
// Flags are set ONLY by SNAP admins; facility admins can read their own but
// never modify. `source` records whether the row came from the tier default
// being materialized or an explicit per-facility override.
model FacilityFeatureFlag {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  flagName   String
  enabled    Boolean
  source     String   @default("OVERRIDE") // TIER | OVERRIDE
  setById    String? // SNAP admin User id who set the override
  setAt      DateTime @default(now())
  notes      String?

  @@unique([facilityId, flagName])
  @@index([facilityId])
}

// Per-facility, per-system payroll template + field mapping. Uploaded once by
// the facility admin; the saved column headers + mapping drive every future
// export so the produced CSV matches exactly what ADP/Gusto expects to ingest.
model PayrollTemplateConfig {
  id           String        @id @default(cuid())
  facilityId   String
  facility     Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  system       PayrollSystem
  templateName String? // original uploaded filename
  // Raw ordered column headers parsed from the uploaded template (String[]).
  headers      Json
  // { snapField: templateHeader } — maps SNAP payroll fields onto the
  // facility's template columns. Built by fuzzy auto-match, admin-confirmable.
  fieldMapping Json
  fileCode     String? // ADP "File Code" / company code, if provided
  uploadedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([facilityId, system])
}

// A single payroll run for one facility, one pay period, one pay class.
// W-2 and 1099/contractor staff export as SEPARATE runs (different files).
// csvContent is the immutable generated export, stored so History can
// re-download the exact file that was produced.
model PayrollRun {
  id             String           @id @default(cuid())
  facilityId     String
  facility       Facility         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  system         PayrollSystem
  payClass       PayrollClass
  periodStart    DateTime
  periodEnd      DateTime
  providerCount        Int              @default(0)
  totalHours           Float            @default(0)
  totalGross           Float            @default(0)
  totalBonus           Float            @default(0)
  totalReimbursement   Float            @default(0)
  // Run-level invoice number — the SAME value for every provider on this run
  // (Gusto's invoice_number column), set once per payroll and incremented each run.
  invoiceNumber  String?
  status         PayrollRunStatus @default(DRAFT)
  csvContent     String? // stored copy of the generated CSV (set on export)
  fileName       String?
  exportedById   String? // facility User id who exported
  exportedByName String?
  exportedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  lineItems PayrollRunProvider[]

  @@index([facilityId, periodStart])
}

// One provider's line on a payroll run. Hours are auto-seeded from available
// shift data then made editable in the review grid; grossPay is recomputed
// from hours x rate. shiftDetail is the expandable per-shift breakdown.
model PayrollRunProvider {
  id              String               @id @default(cuid())
  payrollRunId    String
  payrollRun      PayrollRun           @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  rosterEntryId   String?
  rosterEntry     InternalRosterEntry? @relation(fields: [rosterEntryId], references: [id], onDelete: SetNull)
  providerName    String
  role            String?
  payrollSystemId String? // external payroll-provider employee id (pass-through)
  regularHours    Float                @default(0)
  otHours         Float                @default(0)
  hourlyRate      Float?
  annualRate      Float? // for salaried W-2; gross may derive from this instead
  grossPay        Float                @default(0)
  // Bonus is a SEPARATE payroll line from regular pay (its own CSV column).
  // Final bonus = bonusFlat + bonusHours * bonusRate (any combination). The
  // total lands in the template's "bonus" column; it is NOT added to grossPay.
  bonusFlat       Float? // flat dollar bonus
  bonusHours      Float? // bonus computed from hours...
  bonusRate       Float? // ...at this (often different) hourly rate
  bonusTotal      Float                @default(0)
  // Expense reimbursement paid to the contractor — its own CSV column,
  // separate from gross + bonus.
  reimbursement   Float?
  shiftDetail     Json? // [{ date, start, end, hours, type }]
  approved        Boolean              @default(false)
  approvedById    String?
  approvedAt      DateTime?

  @@index([payrollRunId])
}

// Audit trail of rate changes per roster provider. The current rate lives on
// InternalRosterEntry (hourlyRate/annualRate); this records each change with an
// effective date so historical payroll runs can be explained/reconstructed.
model RosterRateHistory {
  id            String              @id @default(cuid())
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  hourlyRate    Float?
  annualRate    Float?
  effectiveDate DateTime
  setById       String?
  note          String?
  createdAt     DateTime            @default(now())

  @@index([rosterEntryId, effectiveDate])
}

// Per-site settings registry. Locations are otherwise free-text strings across
// the schedule/coverage/hour models; this holds site-level attributes keyed by
// (facility, siteName). `isExternal` = a NON-CAPA site (e.g. an APNE site like
// Melrose): it can still appear on the master schedule, but hours worked there
// are EXCLUDED from the facility's agency invoice (the agency, not the facility,
// pays them). Default false = a normal facility-owned site.
model FacilityLocation {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  siteName   String
  isExternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([facilityId, siteName])
}

// Provider worked-hours entry. The per-day actual hours a 1099/per-diem provider
// (or a coordinator on their behalf) confirms before payroll/invoicing. Seeded
// from the schedule (pre-filled with the location's default shift window from
// CoverageTemplateDay) and/or added manually. W-2 staff don't need entries — they
// are paid regardless. SUBMITTED rows are what the Payroll Builder + Agency
// Invoice consume for 1099s (overriding raw schedule hours). See the provider
// hour-entry feature + eor-model-spec.md.
model ProviderHourEntry {
  id            String              @id @default(cuid())
  facilityId    String
  facility      Facility            @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  location  String?
  startTime String? // "HH:MM" 24h — pre-filled from the location default window
  endTime   String? // "HH:MM" 24h
  hours     Float    @default(0) // computed from the window, editable

  // DRAFT = seeded/in-progress; SUBMITTED = confirmed, ready for payroll/invoice.
  status    String  @default("DRAFT") // DRAFT | SUBMITTED
  // Where the row originated, for provenance/dedup. SCHEDULE = SNAP scheduler;
  // UPLOAD = ingested SchedulingRecord; MANUAL = added by hand; PAYROLL_SHEET =
  // ingested from an APNE-style Gusto 1099 payroll sheet.
  source    String  @default("MANUAL") // SCHEDULE | UPLOAD | MANUAL | PAYROLL_SHEET
  enteredBy String? // 'coordinator' | 'provider' | a user id, for audit

  // APNE payroll-sheet extras (period-level, from the Gusto 1099 feed):
  // reimbursementAmount = a facility-reimbursed pass-through (e.g. mileage) → ADDED
  //   to the agency invoice. bonusAmount = APNE-SITE work (NOT billed to the
  //   facility) — a separate bucket for APNE profitability metrics. bonusDetail
  //   stores the source formula (e.g. "(24*300)+(14*64)") so APNE-site hours/rates
  //   stay recoverable. See eor-model-spec.md / APNE bridge.
  reimbursementAmount Float?
  bonusAmount         Float?
  bonusDetail         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One entry per provider/day/location (a provider can cover two sites in a day).
  @@unique([rosterEntryId, date, location])
  @@index([facilityId, date])
}

// Server-side login sessions (Security HIGH-1). Every issued JWT carries a
// jti that must match a live row here — so tokens are revocable (logout,
// password reset, admin kill) and expiry is enforced server-side, not just
// inside the signed token. Old jti-less tokens are rejected by middleware.
model AuthSession {
  id         String    @id @default(cuid())
  jti        String    @unique // random id embedded in the JWT payload
  audience   String // PROVIDER | FACILITY | ADMIN | CREDENTIAL
  userId     String // User.id or CredentialUser.id (per audience)
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([userId, audience])
  @@index([expiresAt])
}

// A saved agency-invoice export (APNE → CAPA). The live Agency Invoice view
// recomputes from current data, so numbers can drift after hours/rate edits —
// this row freezes exactly what was billed: the line items, totals, and the
// exact exported .xlsx bytes for byte-identical re-download. One row per
// export click.
model AgencyInvoiceRun {
  id            String   @id @default(cuid())
  facilityId    String
  employerId    String?
  employerName  String?
  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date
  invoiceNumber String? // editable after the fact (bookkeeping reference)
  total         Float    @default(0)
  hours         Float    @default(0)
  lines         Json // snapshot of invoice.lines at export time
  fileName      String
  file          Bytes // the exact .xlsx that was downloaded

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId, createdAt])
}

// In-progress Payroll Builder edits (bonus + reimbursement) so leaving the page
// doesn't lose them. One row per provider per pay period per pay class. The
// presence of a row means "the coordinator touched this line" — its values
// override the seeded preview wholesale (including explicit clears, which are
// stored as null). Hours/rates are NOT drafted here: hours persist on
// ProviderHourEntry and rates on the roster card via their own flows.
model PayrollLineDraft {
  id            String   @id @default(cuid())
  facilityId    String
  rosterEntryId String
  payClass      String // W2 | CONTRACTOR
  periodStart   DateTime @db.Date
  periodEnd     DateTime @db.Date

  bonusFlat     Float?
  bonusHours    Float?
  bonusRate     Float?
  reimbursement Float?
  // Row-level "Approved" checkmark in the review grid — persisted so leaving
  // the page doesn't reset the coordinator's review progress.
  approved      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facilityId, rosterEntryId, payClass, periodStart, periodEnd])
  @@index([facilityId, periodStart, periodEnd])
}

// ══════════════════════════════════════════════════════════════════════════════
// EOR (Employer-of-Record) — Phase 0  (added 2026-06-18)
// See capa-pilot/eor-model-spec.md. Half of CAPA's schedule is staffed by 1099s
// who work for APNE, not CAPA; APNE runs payroll off CAPA's ONE master schedule
// and CAPA reimburses certain pass-through costs (malpractice). There is no second
// schedule — an employer gets a filtered LENS over the master schedule. Phase 0
// adds the data primitives only (Employer, link, cost components, the FK on the
// roster). The employer portal + agency-private provider pay are Phase 1.
// ══════════════════════════════════════════════════════════════════════════════

// The Employer-of-Record: who actually pays a provider. Replaces the free-form
// InternalRosterEntry.employer string. One per facility for its own W-2 staff
// (kind=FACILITY_SELF) plus one per external staffing group (APNE, JJM).
model Employer {
  id        String       @id @default(cuid())
  name      String // "APNE", "CAPA", "JJM"
  legalName String? // for invoices / payroll
  ein       String?
  kind      EmployerKind @default(STAFFING_AGENCY)

  // For FACILITY_SELF, the facility this employer IS. Unique so it's a clean
  // one-to-one and CAPA's own W-2 staff resolve to an Employer without nulls.
  ownerFacilityId String?   @unique
  ownerFacility   Facility? @relation("FacilitySelfEmployer", fields: [ownerFacilityId], references: [id])

  facilityLinks EmployerFacilityLink[]
  rosterEntries InternalRosterEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Which facilities an agency may staff (and therefore see a schedule lens for).
// This is the firewall's allow-list. CAPA<->APNE is one row.
model EmployerFacilityLink {
  id         String   @id @default(cuid())
  employerId String
  facilityId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  status     String   @default("ACTIVE") // ACTIVE | PAUSED
  createdAt  DateTime @default(now())

  @@unique([employerId, facilityId])
}

// Itemized cost lines on top of the bill rate. Attach to a roster entry (a
// standing per-provider default) and/or a single assignment (one-off override).
// Makes the savings calc + the APNE->CAPA reimbursement total both correct:
// whether malpractice is deducted-from-rate or paid-directly, CAPA's true outflow
// is the same — model it as an explicit line with paidBy + reimbursable.
model AssignmentCostComponent {
  id            String               @id @default(cuid())
  rosterEntryId String?
  rosterEntry   InternalRosterEntry? @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  assignmentId  String?
  assignment    ScheduleAssignment?  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  type           CostComponentType
  // Per-hour OR per-shift; exactly one is set.
  amountPerHour  Float?
  amountPerShift Float?

  // Who bears the cost, and whether the facility reimburses the employer for it.
  // Malpractice case: paidBy=FACILITY, reimbursable=true.
  paidBy       String  @default("FACILITY") // FACILITY | EMPLOYER | PROVIDER
  reimbursable Boolean @default(false)

  // Agency-private lines (the agency's own margin) are never shown to the
  // facility; reimbursable pass-throughs ARE (the facility owes them).
  facilityVisible Boolean @default(true)

  note      String?
  createdAt DateTime @default(now())

  @@index([rosterEntryId])
  @@index([assignmentId])
}

// ══════════════════════════════════════════════════════════════════════════════
// Marketplace Payment — Position 1 fee ledger (added 2026-06-18)
// ══════════════════════════════════════════════════════════════════════════════

// One row per marketplace ShiftBooking that reaches dual-verified completion.
// SNAP is NOT the payor: this records the 5% platform fee SNAP is owed by the
// facility (the facility pays the provider directly). Accrued as PENDING on
// verification; real charging waits until Stripe billing is wired (then status
// flips to CHARGED/FAILED). Only created when the facility's transaction_fees
// feature flag is ON. Internal shifts never get a row (they have no booking).
model MarketplaceFeeLedger {
  id         String       @id @default(cuid())
  bookingId  String       @unique
  booking    ShiftBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  providerId String

  shiftValue Float // totalShiftValue at accrual time
  feeRate    Float // e.g. 0.05
  feeAmount  Float // shiftValue * feeRate
  status     FeeStatus @default(PENDING)

  accruedAt             DateTime  @default(now())
  chargedAt             DateTime? // set when the Stripe charge succeeds (V-later)
  stripePaymentIntentId String?
  failureReason         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId, status])
  @@index([status, accruedAt])
}

// ── Agreement Acceptance ──────────────────────────────────────────────────────
// Records in-portal click-wrap acceptance of Terms of Service + BAA at the
// moment a facility selects or upgrades a subscription tier.

model AgreementAcceptance {
  id               String   @id @default(cuid())
  facilityId       String
  facility         Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  agreementVersion String   // e.g. "v1.0-2026-06-29"
  tier             String   // tier selected at time of acceptance
  ipAddress        String?
  userAgent        String?
  acceptedAt       DateTime @default(now())

  @@index([facilityId])
}

// ── Benchmark Cohort Consent ──────────────────────────────────────────────────
// In-portal click-wrap consent to StaffIQ benchmark participation (anonymized
// publication, ongoing uploads, reference rights). Deliberately NOT an emailed
// e-signature flow — captured inside the facility portal like the subscription
// agreement, one row per acceptance so history is preserved. The latest
// non-revoked row is the facility's current consent state; revocation is
// prospective (recorded on the row, prior published aggregates unaffected).

model BenchmarkConsent {
  id             String    @id @default(cuid())
  facilityId     String
  facility       Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  consentVersion String    // e.g. "v1.0-2026-07-12"
  ipAddress      String?
  userAgent      String?
  acceptedAt     DateTime  @default(now())
  revokedAt      DateTime?
  revokedById    String?   // userId of the revoking facility user

  @@index([facilityId])
}

// ── Provider Availability Self-Submission ─────────────────────────────────────
// Coordinators send a tokenized link to each internal roster member. The
// provider opens the link (no login required) and marks available/unavailable
// for every day in the target month. Submissions are merged into the schedule
// builder's availability signal (provider layer — admin override still wins).
//
// AvailabilityRequest — one per (facility, rosterEntry, year, month). Created
// when the coordinator clicks "Send" in the Provider Availability panel.
// token is the bearer credential embedded in the link; it never expires but
// the deadline signals when submissions should stop.
model AvailabilityRequest {
  id            String    @id @default(cuid())
  token         String    @unique
  facilityId    String
  rosterEntryId String
  year          Int
  month         Int
  deadline      DateTime
  sentAt        DateTime?
  sentVia       String?   // "SMS" | "EMAIL" | "BOTH"
  submittedAt   DateTime? // when the provider first submitted
  lastUpdatedAt DateTime? // updated on every subsequent submit
  createdAt     DateTime  @default(now())

  facility       Facility            @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  rosterEntry    InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  daySubmissions AvailDaySubmission[]

  @@unique([facilityId, rosterEntryId, year, month])
  @@index([facilityId])
}

// AvailDaySubmission — one row per (request, date). Full-replace on each
// submit: existing rows for the request are deleted, then new ones created.
model AvailDaySubmission {
  id        String   @id @default(cuid())
  requestId String
  date      DateTime @db.Date
  available Boolean
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request AvailabilityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, date])
  @@index([requestId])
}

// ── Facility Room-Count Card ──────────────────────────────────────────────────
// The customer (an anesthesia group like CAPA/Melrose) sends a tokenized,
// no-login link to each LOCATION it covers (BOSS, Kenmore, the endoscopy unit,
// …). The site's own scheduler declares how many anesthetizing rooms run each
// day next month — the authoritative demand input the schedule builder staffs
// against. Mirrors AvailabilityRequest / AvailDaySubmission (one link per
// recipient), but the recipient is a SITE, not a roster member.

// One or two contact emails stored per (facility, location) so that after the
// first setup, sending each month's requests is one click.
model FacilityLocationContact {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  location   String // matches CoverageTemplateDay.location / ScheduleDay.location semantics
  name       String?
  email      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([facilityId, location])
}

model RoomCountRequest {
  id            String    @id @default(cuid())
  token         String    @unique
  facilityId    String
  location      String
  year          Int
  month         Int
  deadline      DateTime
  sentAt        DateTime?
  sentVia       String?   // "EMAIL"
  submittedAt   DateTime? // when the site first submitted (the timestamp shown in the builder)
  lastUpdatedAt DateTime? // updated on every subsequent submit
  createdAt     DateTime  @default(now())

  facility  Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  dayCounts RoomCountDay[]

  @@unique([facilityId, location, year, month])
  @@index([facilityId])
}

// One row per (request, date). Full-replace on each submit, mirroring
// AvailDaySubmission.
model RoomCountDay {
  id            String   @id @default(cuid())
  requestId     String
  date          DateTime @db.Date
  roomsRequired Int
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  request RoomCountRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, date])
  @@index([requestId])
}
