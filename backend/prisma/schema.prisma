generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is the Neon POOLER endpoint (for runtime queries).
  // `prisma db push` works fine on the pooler. (If we ever switch to
  // `prisma migrate deploy`, we'll need to add `directUrl = env("DIRECT_URL")`
  // and ensure Neon's direct endpoint is reachable.)
  url = env("DATABASE_URL")
}

enum UserRole {
  PROVIDER
  FACILITY_USER
  ADMIN
}

enum Specialty {
  CRNA
  ANESTHESIOLOGIST
  ANESTHESIA_ASSISTANT
}

enum NotifPreference {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_SUMMARY
  NONE
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum ShiftStatus {
  DEPOSIT_PENDING
  LIVE
  FILLED
  COMPLETED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VIPReason {
  DAILY_LOGIN
  CALENDAR_UPDATED
  SHIFT_ACCEPTED
  SHIFT_COMPLETED
  HIGH_RATING
}

enum FacilityType {
  HOSPITAL
  SURGERY_CENTER
  OUTPATIENT
  DENTAL
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
}

// ── SNAP Shifts enums ─────────────────────────────────────────────────────────

enum SnapMode {
  MARKETPLACE
  SHIFTS
  BOTH
}

enum EmploymentCategory {
  FULL_TIME
  PER_DIEM
  LOCUMS
}

enum IncentiveShiftStatus {
  OPEN
  FILLED
  EXPIRED
  ESCALATED
}

enum AvailabilityWindowStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum InsightType {
  LATE_SCHEDULING
  PROVIDER_MIX
  DEMAND_FORECAST
  UTILIZATION
}

enum CalculatorType {
  AGENCY_REPLACEMENT
  EFFICIENCY
}

enum LeadFollowUpStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  CUSTOMER
  NOT_INTERESTED
}

// ── SNAP Credentialing enums ──────────────────────────────────────────────────

enum CredentialPermission {
  COORDINATOR
  DEPT_HEAD
  BILLING
}

enum CredentialType {
  STATE_LICENSE
  DEA_CERTIFICATE
  MA_CS_LICENSE
  BOARD_CERTIFICATION
  MALPRACTICE_INSURANCE
  MALPRACTICE_HISTORY
  ACLS_CERTIFICATION
  BLS_CERTIFICATION
  EDUCATION_HISTORY
  HOSPITAL_PRIVILEGES
  WORK_HISTORY
  NPDB_AUTHORIZATION
  CV
}

enum CredStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  MISSING
  PENDING
}

enum RosterMatchStatus {
  LINKED
  INVITED
  NOT_INVITED
}

// ── Existing models ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  role      UserRole @default(PROVIDER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerProfile           ProviderProfile?
  facilityMemberships       FacilityUser[]
  scheduleBuildRunsTriggered ScheduleBuildRun[]
}

model ProviderProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName             String?
  lastName              String?
  specialty             Specialty?
  additionalSpecialties Specialty[]
  yearsExperience       Int?
  city                  String?
  zipCode               String?
  state                 String      @default("MA")
  lat                   Float?
  lng                   Float?
  photoUrl              String?

  pin       String?
  npiNumber String? @unique

  credentialed          Boolean   @default(false)
  maLicenseNumber       String?
  maLicenseExpiry       DateTime?
  maLicenseAcknowledged Boolean   @default(false)

  personalStatement    String?
  equipmentPreferences String?
  caseMixExperience    String?

  vipPoints   Int       @default(0)
  vipStatus   Boolean   @default(false)
  vipEarnedAt DateTime?
  lastLoginAt DateTime?

  notifPreference NotifPreference @default(IMMEDIATE)
  notifSurge      Boolean         @default(true)
  expoPushToken   String?

  profileCompletePct Int @default(0)

  applications            ShiftApplication[]
  bookings                ShiftBooking[]
  completions             ShiftCompletion[]
  availability            ProviderAvailability[]
  ratingsReceived         ProviderRating[]
  facilityRatings         FacilityRating[]
  preferredAt             PreferredProvider[]
  vipLogs                 VIPPointsLog[]
  sentMessages            Message[]
  availabilitySubmissions AvailabilitySubmission[]
  credentials             ProviderCredential[]
  rosterEntries           FacilityRosterEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Facility {
  id           String        @id @default(cuid())
  name         String
  facilityType FacilityType?
  address      String?
  zipCode      String?
  state        String        @default("MA")
  lat          Float?
  lng          Float?
  photoUrls    String[]
  description  String?
  caseMix      String?
  parking      String?
  whatToBring  String?
  profileScore Int           @default(0)
  snapMode     SnapMode      @default(MARKETPLACE)
  // Industry-standard fully-loaded cost to staff one anesthetizing location
  // for one day ($/room/day), entered by the coordinator. Used as the
  // "old manual process" baseline the SNAP-built schedule is compared against
  // on the Schedule Builder (baseline = rate x room-days covered).
  industryRoomRatePerDay Float?

  users               FacilityUser[]
  subscription        FacilitySubscription?
  shifts              Shift[]
  preferredProviders  PreferredProvider[]
  providerRatings     ProviderRating[]
  facilityRatings     FacilityRating[]
  messages            Message[]
  rosterEntries       InternalRosterEntry[]
  availabilityWindows AvailabilityWindow[]
  scheduleDays        ScheduleDay[]
  schedulingUploads   SchedulingUpload[]
  scheduleFeedback    ScheduleFeedback[]
  schedulingRecords   SchedulingRecord[]
  staffiqInsights     StaffIQInsight[]
  incentiveShifts     InternalIncentiveShift[]
  staffiqInputs       StaffIQInput[]
  staffiqScoreHistory StaffIQScoreHistory[]
  credentialUsers     CredentialUser[]
  credRosterEntries   FacilityRosterEntry[]
  coverageTemplates   CoverageTemplate[]
  holidays            FacilityHoliday[]
  scheduleBuildRuns   ScheduleBuildRun[]
  automationEvents    AutomationEvent[]
  providerLocations   ProviderLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacilityUser {
  id           String   @id @default(cuid())
  userId       String
  facilityId   String
  facilityRole String   @default("SCHEDULER")
  user         User     @relation(fields: [userId], references: [id])
  facility     Facility @relation(fields: [facilityId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([userId, facilityId])
}

model FacilitySubscription {
  id                    String           @id @default(cuid())
  facilityId            String           @unique
  facility              Facility         @relation(fields: [facilityId], references: [id])
  tier                  SubscriptionTier @default(BASIC)
  status                String           @default("ACTIVE")
  shiftsPostedThisMonth Int              @default(0)
  monthResetAt          DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Shift {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id])

  specialty       Specialty
  date            DateTime
  startTime       String
  durationHours   Float
  baseRate        Float
  currentRate     Float
  surgeEnabled    Boolean     @default(false)
  surgeMultiplier Float       @default(1.0)
  featured        Boolean     @default(false)
  status          ShiftStatus @default(DEPOSIT_PENDING)

  preferredAccessOnly Boolean   @default(false)
  preferredWindowEnds DateTime?

  expiresAt      DateTime?
  currentViewers Int       @default(0)

  estimatedTotal     Float?
  depositAmount      Float?
  depositConfirmed   Boolean   @default(false)
  depositConfirmedAt DateTime?

  platformFeePercent Float         @default(10.0)
  platformFeeAmount  Float?
  paymentStatus      PaymentStatus @default(PENDING)
  paymentSettledAt   DateTime?

  applications ShiftApplication[]
  booking      ShiftBooking?
  completions  ShiftCompletion[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftApplication {
  id         String            @id @default(cuid())
  shiftId    String
  providerId String
  shift      Shift             @relation(fields: [shiftId], references: [id])
  provider   ProviderProfile   @relation(fields: [providerId], references: [id])
  status     ApplicationStatus @default(PENDING)
  appliedAt  DateTime          @default(now())
  reviewedAt DateTime?

  @@unique([shiftId, providerId])
}

model ShiftBooking {
  id         String          @id @default(cuid())
  shiftId    String          @unique
  providerId String
  shift      Shift           @relation(fields: [shiftId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  providerHourlyRate Float?
  shiftDurationHours Float?
  totalShiftValue    Float?
  platformFeePercent Float?
  platformFeeAmount  Float?
  facilityTier       SubscriptionTier?

  paymentStatus PaymentStatus @default(PENDING)
  confirmedAt   DateTime      @default(now())
  completedAt   DateTime?
  cancelledAt   DateTime?

  providerRating ProviderRating?
  facilityRating FacilityRating?
  completion     ShiftCompletion?

  createdAt DateTime @default(now())
}

model ShiftCompletion {
  id         String          @id @default(cuid())
  shiftId    String
  bookingId  String          @unique
  providerId String
  shift      Shift           @relation(fields: [shiftId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  providerConfirmed   Boolean   @default(false)
  providerHours       Float?
  providerNotes       String?
  providerConfirmedAt DateTime?

  facilityConfirmed   Boolean   @default(false)
  facilityHours       Float?
  facilityNotes       String?
  facilityConfirmedAt DateTime?

  disputed          Boolean   @default(false)
  disputeResolvedAt DateTime?
  disputeNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderAvailability {
  id         String          @id @default(cuid())
  providerId String
  date       DateTime        @db.Date
  available  Boolean
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())

  @@unique([providerId, date])
}

model ProviderRating {
  id         String          @id @default(cuid())
  facilityId String
  providerId String
  bookingId  String          @unique
  stars      Int
  notes      String?
  facility   Facility        @relation(fields: [facilityId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  createdAt  DateTime        @default(now())
}

model FacilityRating {
  id         String          @id @default(cuid())
  providerId String
  facilityId String
  bookingId  String          @unique
  stars      Int
  notes      String?
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  facility   Facility        @relation(fields: [facilityId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  createdAt  DateTime        @default(now())
}

model PreferredProvider {
  id         String          @id @default(cuid())
  facilityId String
  providerId String
  facility   Facility        @relation(fields: [facilityId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  addedAt    DateTime        @default(now())

  @@unique([facilityId, providerId])
}

model VIPPointsLog {
  id         String          @id @default(cuid())
  providerId String
  points     Int
  reason     VIPReason
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())
}

model Message {
  id         String          @id @default(cuid())
  shiftId    String
  facilityId String
  senderId   String
  body       String
  flagged    Boolean         @default(false)
  readAt     DateTime?
  shift      Shift           @relation(fields: [shiftId], references: [id])
  facility   Facility        @relation(fields: [facilityId], references: [id])
  sender     ProviderProfile @relation(fields: [senderId], references: [id])
  createdAt  DateTime        @default(now())
}

// ── SNAP Shifts models ────────────────────────────────────────────────────────

model InternalRosterEntry {
  id                 String             @id @default(cuid())
  facilityId         String
  facility           Facility           @relation(fields: [facilityId], references: [id])
  providerName       String
  // Nullable so non-clinical roster members (back-office staff, billers)
  // can be on the roster for payroll without a clinical specialty. Clinical
  // scheduling explicitly excludes rows where providerType is null OR
  // isNonClinical is true (see scheduleBuilder.js + isNonClinical below).
  providerType       Specialty?
  employmentCategory EmploymentCategory?
  // True for back-office / non-clinical staff who belong on the roster for
  // payroll purposes but are never scheduled into ORs and don't need an NPI.
  isNonClinical      Boolean            @default(false)
  // True when the coordinator has explicitly marked this person as not
  // needing an NPI (back-office staff, or a provider they'll handle out of
  // band). Exempt rows are excluded from the NPI review queue. Auto-set true
  // for non-clinical imports.
  npiExempt          Boolean            @default(false)
  snapAccountEmail   String?
  phoneNumber        String?
  // NPI (National Provider Identifier) — primary key for matching this
  // roster entry to an existing ProviderProfile across the marketplace.
  // 10-digit string; unique-per-facility because the same provider could
  // (rarely) be on two practices' rosters as a locum.
  npi                String?
  // Customer-internal provider code (e.g. CAPA's "Initials" field). Used
  // as the join key when a multi-sheet xlsx import bundles identity,
  // payroll, and per-location credentialing across separate tabs. NOT a
  // SNAP-wide identifier — only meaningful within ONE facility's roster.
  rosterCode         String?
  // External payroll-system identifier (Gusto / ADP / Paychex / etc).
  // Pass-through field so the SNAP Payroll tab can export weekly
  // summaries that link back to the customer's payroll provider rows.
  payrollSystemId    String?
  // NPPES lookup state. Set when the import couldn't auto-attach an NPI
  // (multiple matches or zero matches in NPPES). The disambiguation UI
  // surfaces these for coordinator resolution. Cleared once npi is set.
  npiLookupStatus    String?            // 'NEEDS_DISAMBIGUATION' | 'NO_MATCH' | 'INVALID_NAME'
  npiLookupCandidates Json?             // array of NPPES match objects for the disambiguation UI
  licenseNumber      String?
  licenseExpiration  DateTime?
  notes              String?
  snapAccountLinked  Boolean            @default(false)
  linkedProviderId   String?
  inviteSentAt       DateTime?
  // Credentialing-invite lifecycle, distinct from snapAccountLinked (which is
  // a *marketplace* account). Flips NOT_INVITED → INVITED when a coordinator
  // sends a credentialing invite; CLAIMED/COMPLETED are synced back from the
  // passport bridge (a live grant means the provider claimed + consented).
  credentialingStatus String            @default("NOT_INVITED") // NOT_INVITED | INVITED | CLAIMED | COMPLETED
  // True for providers already credentialed via the manual/legacy process.
  // Excluded from "Invite all" — their SNAP credentialing is deferred to their
  // next license renewal so we don't disrupt active credentials. Explicitly
  // selecting them in the invite modal overrides this.
  externallyCredentialed Boolean         @default(false)
  createdAt          DateTime           @default(now())

  // Employment-specific preference fields
  fteHours             Float? // FULL_TIME: hours per week
  annualRate           Float? // FULL_TIME: annual base salary
  hourlyRate           Float? // PER_DIEM / LOCUMS: hourly rate
  preferredShiftLength String? // "8hr" | "10hr" | "12hr" | "none"
  preferredDays        Json? // String[] e.g. ["Mon","Tue","Wed"]
  locationRankings     Json? // Array of location name strings (ranked)
  maxShiftsPerMonth    Int? // PER_DIEM: cap on shifts
  contractStart        DateTime? // LOCUMS: contract start
  contractEnd          DateTime? // LOCUMS: contract end

  // Reliability score 0.0-1.0 used by Schedule Builder v2 quality algorithm.
  // Computed by a future background job from ShiftCompletion history (no-shows,
  // late arrivals, cancellations). null = not yet computed; algorithm treats
  // null as the practice's average (currently 0.85 as a sensible default).
  reliabilityScore     Float?

  scheduleAssignments ScheduleAssignment[]
  incentiveResponses  InternalIncentiveShiftResponse[]
  scheduleFeedback    ScheduleFeedback[]
  locations           ProviderLocation[]
  timeOff             RosterTimeOff[]

  @@index([rosterCode])
  @@index([facilityId, npi])
}

// Provider time off / PTO. Keyed on the roster entry (not a SNAP
// ProviderProfile) so it works for every roster member — including the
// many CAPA providers without a linked SNAP account. The Schedule Builder
// HARD-excludes anyone with time off covering a date (never auto-assigns
// them), and the day editor grays them out. Inclusive date range
// [startDate, endDate]. v1 is coordinator-entered; provider self-request +
// approval workflow is v1.1.
model RosterTimeOff {
  id            String              @id @default(cuid())
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  facilityId    String
  startDate     DateTime            @db.Date
  endDate       DateTime            @db.Date
  reason        String?
  createdAt     DateTime            @default(now())

  @@index([facilityId, startDate, endDate])
  @@index([rosterEntryId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ProviderLocation — per-provider × per-location credentialing matrix.
//
// One row per (rosterEntry, facilityName) pair. Binary: presence of the row
// means "this provider is credentialed to work at this location." Used by:
//   - Schedule Builder v2 eligibility filter (only assign providers to rooms
//     at locations they're credentialed at)
//   - Per-facility coordinator views ("show me everyone at Kenmore")
//   - Future: non-hospital facility wedge (Task #17 — ASCs/clinics declare
//     lighter required credential sets per location)
//
// facilityName is the raw string from the customer's source data (e.g. CAPA's
// "Facility 1..41" sheet cell values). facilityId is an optional FK to a
// Facility row if the name happens to match an existing facility. Most
// customer-internal location names will NOT match the marketplace Facility
// table (they're CAPA's own surgery centers), so facilityId stays null.
// ─────────────────────────────────────────────────────────────────────────────

model ProviderLocation {
  id            String              @id @default(cuid())
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  // Raw location name from customer's source (e.g. "Atrius Kenmore",
  // "Shields Natick"). Normalization across spelling variants is deferred
  // to a follow-up — exact-match dedupe for v1.
  facilityName  String
  // Optional FK to a Facility row when the name matches one on the
  // marketplace side. Stays null for customer-internal locations that
  // don't exist as marketplace Facility rows.
  facilityId    String?
  facility      Facility?           @relation(fields: [facilityId], references: [id])
  createdAt     DateTime            @default(now())

  @@unique([rosterEntryId, facilityName])
  @@index([facilityName])
}

model ScheduleFeedback {
  id               String              @id @default(cuid())
  facilityId       String
  facility         Facility            @relation(fields: [facilityId], references: [id])
  rosterId         String
  rosterEntry      InternalRosterEntry @relation(fields: [rosterId], references: [id])
  shiftDate        DateTime            @db.Date
  facilityLocation String
  wasSuggested     Boolean
  suggestionRank   Int?
  wasSelected      Boolean
  shiftCompleted   Boolean             @default(false)
  createdAt        DateTime            @default(now())
}

model AvailabilityWindow {
  id         String                   @id @default(cuid())
  facilityId String
  facility   Facility                 @relation(fields: [facilityId], references: [id])
  windowName String
  openDate   DateTime
  closeDate  DateTime
  message    String?
  notifyAll  Boolean                  @default(true)
  status     AvailabilityWindowStatus @default(DRAFT)
  createdAt  DateTime                 @default(now())

  submissions AvailabilitySubmission[]
}

model AvailabilitySubmission {
  id          String             @id @default(cuid())
  windowId    String
  providerId  String
  facilityId  String
  window      AvailabilityWindow @relation(fields: [windowId], references: [id])
  provider    ProviderProfile    @relation(fields: [providerId], references: [id])
  submittedAt DateTime           @default(now())

  @@unique([windowId, providerId])
}

model ScheduleDay {
  id            String    @id @default(cuid())
  facilityId    String
  date          DateTime  @db.Date
  location      String
  roomsRequired Int       @default(1)
  // Coverage model copied from the template at generation time. null =
  // MD-only; 3 = team 1:3; 4 = team 1:4. See CoverageTemplateDay.
  supervisionRatio Int?
  publishedAt   DateTime?
  facility      Facility  @relation(fields: [facilityId], references: [id])

  assignments ScheduleAssignment[]

  @@unique([facilityId, date, location])
}

model ScheduleAssignment {
  id            String               @id @default(cuid())
  scheduleDayId String
  scheduleDay   ScheduleDay          @relation(fields: [scheduleDayId], references: [id])
  roomNumber    Int
  rosterId      String?
  rosterEntry   InternalRosterEntry? @relation(fields: [rosterId], references: [id])
  facilityId    String
  // Care-team role (Task #21 Phase B). null = legacy/role-agnostic room;
  // CRNA_ROOM / SOLO_MD_ROOM = a real OR room; SUPERVISING_MD = an
  // anesthesiologist supervising CRNA rooms (stored at roomNumber >= 900).
  role          String?
  createdAt     DateTime             @default(now())

  @@unique([scheduleDayId, roomNumber])
}

model SchedulingUpload {
  id             String    @id @default(cuid())
  facilityId     String
  facility       Facility  @relation(fields: [facilityId], references: [id])
  fileName       String
  rowCount       Int       @default(0)
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  status         String    @default("PROCESSED")
  uploadedAt     DateTime  @default(now())

  records SchedulingRecord[]
}

model SchedulingRecord {
  id               String            @id @default(cuid())
  facilityId       String
  facility         Facility          @relation(fields: [facilityId], references: [id])
  providerName     String?
  providerType     String?
  shiftDate        DateTime?
  startTime        String?
  endTime          String?
  durationHours    Float?
  facilityLocation String?
  caseType         String?
  rate             Float?
  sourceUploadId   String?
  sourceUpload     SchedulingUpload? @relation(fields: [sourceUploadId], references: [id])
  createdAt        DateTime          @default(now())
}

model StaffIQInsight {
  id                   String      @id @default(cuid())
  facilityId           String
  facility             Facility    @relation(fields: [facilityId], references: [id])
  generatedAt          DateTime    @default(now())
  insightType          InsightType
  insightData          Json
  dollarImpactEstimate Float?
  dataPointsAnalyzed   Int?
}

model InternalIncentiveShift {
  id                     String               @id @default(cuid())
  facilityId             String
  facility               Facility             @relation(fields: [facilityId], references: [id])
  shiftDate              DateTime
  startTime              String
  durationHours          Float
  facilityLocation       String
  incentiveRate          Float
  providerTypeRequired   Specialty
  responseDeadline       DateTime
  status                 IncentiveShiftStatus @default(OPEN)
  escalatedToMarketplace Boolean              @default(false)
  escalationApprovedAt   DateTime?
  escalationApprovedBy   String?
  marketplaceShiftId     String?
  createdAt              DateTime             @default(now())

  responses InternalIncentiveShiftResponse[]
}

model InternalIncentiveShiftResponse {
  id          String                 @id @default(cuid())
  shiftId     String
  shift       InternalIncentiveShift @relation(fields: [shiftId], references: [id])
  rosterId    String
  rosterEntry InternalRosterEntry    @relation(fields: [rosterId], references: [id])
  accepted    Boolean
  respondedAt DateTime               @default(now())

  @@unique([shiftId, rosterId])
}

model StaffIQCalculatorResult {
  id              String         @id @default(cuid())
  calculatorType  CalculatorType
  facilityName    String?
  contactName     String?
  email           String?
  inputData       Json
  outputData      Json
  reportGenerated Boolean        @default(false)
  reportSent      Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

model Lead {
  id              String             @id @default(cuid())
  source          String             @default("calculator")
  facilityName    String?
  contactName     String?
  email           String
  calculatorType  CalculatorType?
  savingsEstimate Float?
  reportSentAt    DateTime?
  followUpStatus  LeadFollowUpStatus @default(NEW)
  createdAt       DateTime           @default(now())
}

model StaffIQInput {
  id                              String   @id @default(cuid())
  facilityId                      String
  facility                        Facility @relation(fields: [facilityId], references: [id])
  totalLocations                  Int
  avgRoomsPerDay                  Float
  ftAnesthesiologists             Int
  ftCrnas                         Int
  pdAnesthesiologistsPerMonth     Int
  pdCrnasPerMonth                 Int
  agencyAnesthesiologistsPerMonth Int
  agencyCrnasPerMonth             Int
  avgAnesthesiologistRate         Float
  avgCrnaRate                     Float
  avgShiftHours                   Float    @default(10)
  operatingDaysPerYear            Int      @default(250)
  primaryTeamModel                String
  staffiqScore                    Int
  inefficiency1Pct                Float
  inefficiency2Pct                Float
  inefficiency1Cost               Float
  inefficiency2Cost               Float
  totalBudget                     Float
  calculatedAt                    DateTime @default(now())
  createdAt                       DateTime @default(now())
}

model StaffIQScoreHistory {
  id                String   @id @default(cuid())
  facilityId        String
  facility          Facility @relation(fields: [facilityId], references: [id])
  score             Int
  calculationMethod String
  calculatedAt      DateTime @default(now())
}

model CalculatorLead {
  id                String    @id @default(cuid())
  facilityName      String
  contactName       String
  email             String
  phone             String?
  locationsInput    Int
  providersInput    Int
  hourlyRateInput   Float
  estimatedBudget   Float
  inefficiency1Cost Float
  inefficiency2Cost Float
  totalInefficiency Float
  reportGenerated   Boolean   @default(false)
  reportSentAt      DateTime?
  followUpStatus    String    @default("NEW")
  createdAt         DateTime  @default(now())
}

// ── SNAP Credentialing models ─────────────────────────────────────────────────

model CredentialUser {
  id                  String               @id @default(cuid())
  facilityId          String
  facility            Facility             @relation(fields: [facilityId], references: [id])
  name                String
  email               String               @unique
  passwordHash        String
  permission          CredentialPermission @default(COORDINATOR)
  forcePasswordChange Boolean              @default(false)
  isActive            Boolean              @default(true)
  resetToken          String?
  resetTokenExpiresAt DateTime?
  createdAt           DateTime             @default(now())
  lastLoginAt         DateTime?

  verifications CredentialVerification[]
  flags         CredentialFlag[]
  notes         FacilityCredentialNote[]
  accessLogs    CredentialAccessLog[]
}

model FacilityRosterEntry {
  id                 String            @id @default(cuid())
  facilityId         String
  facility           Facility          @relation(fields: [facilityId], references: [id])
  providerId         String?
  provider           ProviderProfile?  @relation(fields: [providerId], references: [id])
  npiNumber          String
  firstName          String
  lastName           String
  credentialType     String
  employmentCategory String?
  department         String?
  notes              String?
  matchStatus        RosterMatchStatus @default(NOT_INVITED)
  invitationSentAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  credentials ProviderCredential[]

  @@unique([facilityId, npiNumber])
}

model ProviderCredential {
  id                 String               @id @default(cuid())
  providerId         String?
  provider           ProviderProfile?     @relation(fields: [providerId], references: [id])
  rosterId           String?
  rosterEntry        FacilityRosterEntry? @relation(fields: [rosterId], references: [id])
  credentialType     CredentialType
  status             CredStatus           @default(PENDING)
  expirationDate     DateTime?
  issueDate          DateTime?
  data               Json?
  documentPath       String?
  documentName       String?
  documentSize       Int?
  documentUploadedAt DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  verifications CredentialVerification[]
  flags         CredentialFlag[]
  notes         FacilityCredentialNote[]
  reminders     CredentialReminder[]

  @@unique([rosterId, credentialType])
}

model CredentialVerification {
  id           String             @id @default(cuid())
  facilityId   String
  credentialId String
  credential   ProviderCredential @relation(fields: [credentialId], references: [id])
  verifiedById String
  verifiedBy   CredentialUser     @relation(fields: [verifiedById], references: [id])
  verifiedAt   DateTime           @default(now())
  notes        String?

  @@unique([facilityId, credentialId])
}

model CredentialFlag {
  id           String             @id @default(cuid())
  facilityId   String
  credentialId String
  credential   ProviderCredential @relation(fields: [credentialId], references: [id])
  flaggedById  String
  flaggedBy    CredentialUser     @relation(fields: [flaggedById], references: [id])
  flaggedAt    DateTime           @default(now())
  resolvedAt   DateTime?
  notes        String?
}

model FacilityCredentialNote {
  id           String              @id @default(cuid())
  facilityId   String
  providerId   String
  credentialId String?
  credential   ProviderCredential? @relation(fields: [credentialId], references: [id])
  noteText     String
  createdById  String
  createdBy    CredentialUser      @relation(fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
}

model CredentialAccessLog {
  id             String         @id @default(cuid())
  facilityId     String
  userId         String
  user           CredentialUser @relation(fields: [userId], references: [id])
  providerId     String
  credentialType String?
  action         String
  documentName   String?
  ipAddress      String?
  timestamp      DateTime       @default(now())
}

model CredentialReminder {
  id             String             @id @default(cuid())
  facilityId     String
  credentialId   String
  credential     ProviderCredential @relation(fields: [credentialId], references: [id])
  reminderType   String
  sentAt         DateTime           @default(now())
  expirationDate DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// SNAP Shifts — Coverage Templates
//
// Per-practice templates capturing standard staffing patterns (locations ×
// day-of-week × room count). Used to bulk-materialize ScheduleDay rows when
// a coordinator generates a new month's schedule. See
// docs/coverage-templates-design.md for the full design (incl. v1.1 plans
// for per-site coverage rules that feed StaffIQ).
// ─────────────────────────────────────────────────────────────────────────────

model CoverageTemplate {
  id         String                @id @default(cuid())
  facilityId String
  facility   Facility              @relation(fields: [facilityId], references: [id])
  name       String // e.g. "Standard Week", "Summer Schedule"
  isDefault  Boolean               @default(false) // practice's default pick
  days       CoverageTemplateDay[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([facilityId, name])
  @@index([facilityId, isDefault])
}

model CoverageTemplateDay {
  id            String           @id @default(cuid())
  templateId    String
  template      CoverageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  location      String // free text — matches ScheduleDay.location string semantics
  dayOfWeek     Int // 0=Sunday … 6=Saturday
  roomsRequired Int              @default(1)

  // Anesthesia care-team model. null = MD-only (every room a solo
  // anesthesiologist). 3 = team 1:3, 4 = team 1:4 (rooms staffed by CRNAs,
  // supervised by anesthesiologists at this ratio). Stored per location-day
  // so a site can be team model on weekdays, MD-only on weekends. The
  // builder's supervision-assignment logic consumes this (Task #21).
  supervisionRatio Int?

  @@unique([templateId, location, dayOfWeek])
}

enum HolidaySource {
  PRACTICE_ADDED // practice-defined holiday in addition to federal calendar
  PRACTICE_EXCLUDED // practice opted out of a normally-federal holiday
}

model FacilityHoliday {
  id         String        @id @default(cuid())
  facilityId String
  facility   Facility      @relation(fields: [facilityId], references: [id])
  date       DateTime      @db.Date
  label      String
  source     HolidaySource

  @@unique([facilityId, date])
  @@index([facilityId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// SNAP Shifts — Schedule Builder v2
//
// Stores each "Build the Schedule" attempt so the coordinator can compare
// candidates side-by-side, and so we accumulate the data StaffIQ learns
// from over time. See docs/schedule-builder-v2-design.md.
// ─────────────────────────────────────────────────────────────────────────────

enum BuildMode {
  COST_EFFICIENT
  HIGHEST_QUALITY
  HYBRID
  STAFFIQ
}

enum BuildRunStatus {
  RUNNING
  COMPLETE
  FAILED
  SUPERSEDED // newer run for the same month replaced this one
}

model ScheduleBuildRun {
  id           String         @id @default(cuid())
  facilityId   String
  facility     Facility       @relation(fields: [facilityId], references: [id])
  year         Int
  month        Int // 1-12
  buildBatchId String // groups multi-mode runs triggered together
  mode         BuildMode
  status       BuildRunStatus

  // Snapshot of input state — enough to reproduce + explain the run later.
  // Includes ScheduleDay rows + the roster + availability + holidays.
  inputSnapshot Json

  // Output: array of { scheduleDayId, roomNumber, rosterId } objects.
  // Stored as JSON so we can compare 4 candidates without writing to
  // ScheduleAssignment until the coordinator selects one.
  assignments Json

  staffiqScore Int? // 0-100, null while RUNNING or FAILED
  insights     Json? // { totalCost, locumsUsed, avgSeniority, ... }
  warnings     String[] // human-readable: "Could not staff Kenmore Mon 8/4"

  // StaffIQ CRNA-gap recommendations (Task #26): { gaps: [...], total... }.
  // Each gap = a team-location-day where CRNAs were short and MDs backfilled,
  // with the dollar penalty + the savings from incentivizing CRNAs.
  staffiqRecommendations Json?

  selectedAt        DateTime? // when coordinator picked this run as active
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  triggeredByUserId String
  triggeredByUser   User      @relation(fields: [triggeredByUserId], references: [id])

  @@index([facilityId, year, month, buildBatchId])
  @@index([facilityId, selectedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Automation events — time-saved tracking for the "Cost Savings" widget on
// the marketplace facility credentialing portal + SNAP Shifts dashboard + the
// SNAP admin aggregate page. One row per discrete automation action that
// would have otherwise taken coordinator/SNAP-team time. Minutes-saved is
// fixed per event type (services/automationEvents.js MINUTES_BY_TYPE) so the
// totals are predictable and not based on per-event guesses.
//
// facilityId nullable for SNAP-level events that don't belong to a facility
// (rare for v1; mostly populated). Aggregating across all rows yields the
// SNAP admin "total impact" number.
//
// $50/hour conversion happens at read time in the helper — not stored — so
// the rate can be retuned later without a schema migration.
// ─────────────────────────────────────────────────────────────────────────────

model AutomationEvent {
  id           String              @id @default(cuid())
  facilityId   String?
  facility     Facility?           @relation(fields: [facilityId], references: [id])
  type         AutomationEventType
  minutesSaved Int
  metadata     Json?
  eventAt      DateTime            @default(now())

  @@index([facilityId, eventAt])
  @@index([type, eventAt])
}

enum AutomationEventType {
  // Marketplace + SNAP Shifts (high-time-saving coordinator-replacing flows)
  ROSTER_UPLOAD              // 180 min — bulk roster CSV/Excel ingestion
  COVERAGE_TEMPLATE_GENERATE // 120 min — month-of-schedule from a template
  SCHEDULE_BUILD_RUN         // 240 min — Schedule Builder v2 4-mode build

  // Credentialing portal (lower per-event, higher frequency)
  SIGNATURE_REQUEST_SENT     // 45 min  — coordinator fires a sig request
  PASSPORT_GRANT_REQUEST     // 30 min  — coordinator fires a grant request

  // Future (wire when feature ships):
  //   NPPES_AUTOFILL        // 30 min per credential
  //   SEALED_PDF_SNAPSHOT   // 60 min — coordinator skips manual file assembly
  //   FORM_READER           // 60 min — external hospital form auto-fill
}
