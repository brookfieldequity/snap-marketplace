generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is the Neon POOLER endpoint (for runtime queries).
  // `prisma db push` works fine on the pooler. (If we ever switch to
  // `prisma migrate deploy`, we'll need to add `directUrl = env("DIRECT_URL")`
  // and ensure Neon's direct endpoint is reachable.)
  url      = env("DATABASE_URL")
}

enum UserRole {
  PROVIDER
  FACILITY_USER
  ADMIN
}

enum Specialty {
  CRNA
  ANESTHESIOLOGIST
  ANESTHESIA_ASSISTANT
}

enum NotifPreference {
  IMMEDIATE
  DAILY_DIGEST
  WEEKLY_SUMMARY
  NONE
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum ShiftStatus {
  DEPOSIT_PENDING
  LIVE
  FILLED
  COMPLETED
  CANCELLED
  EXPIRED
  DISPUTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VIPReason {
  DAILY_LOGIN
  CALENDAR_UPDATED
  SHIFT_ACCEPTED
  SHIFT_COMPLETED
  HIGH_RATING
}

enum FacilityType {
  HOSPITAL
  SURGERY_CENTER
  OUTPATIENT
  DENTAL
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
}

// SNAP's own platform-fee collection state on a marketplace shift (Position 1).
// Distinct from PaymentStatus (which tracks the provider's pay). NOT_APPLICABLE
// = internal shift or transaction_fees flag off; PENDING = fee accrued/owed but
// not yet charged (no Stripe yet); CHARGED/FAILED = once Stripe is wired (V-later).
enum FeeStatus {
  NOT_APPLICABLE
  PENDING
  CHARGED
  FAILED
}

// ── SNAP Shifts enums ─────────────────────────────────────────────────────────

enum SnapMode {
  MARKETPLACE
  SHIFTS
  BOTH
}

enum EmploymentCategory {
  FULL_TIME
  PER_DIEM
  LOCUMS
}

// ── Payroll Builder enums ─────────────────────────────────────────────────────

// External payroll provider the facility uses. The uploaded template + field
// mapping is keyed on this. Extend as new providers onboard (Paychex, etc).
enum PayrollSystem {
  ADP
  GUSTO
}

// Pay class a payroll run is scoped to. Runs are split by class so W-2 staff
// and 1099/contractors export as separate files (different tax handling, often
// different templates). Derived from the roster card's is1099 flag.
enum PayrollClass {
  W2
  CONTRACTOR
}

enum PayrollRunStatus {
  DRAFT
  EXPORTED
}

// ── EOR (Employer-of-Record) enums — see capa-pilot/eor-model-spec.md ──────────
// Who pays a provider for a shift. Promotes the free-form
// InternalRosterEntry.employer string to a first-class entity so an employer
// (e.g. APNE) can have its own roster lens, payroll, and provider-pay data the
// facility never sees. Phase 0 = correctness only (honest savings calc +
// reimbursement totals); the employer portal is Phase 1.
enum EmployerKind {
  FACILITY_SELF // the facility employing its own W-2 staff (CAPA pays CAPA staff)
  STAFFING_AGENCY // external EOR that staffs the facility (APNE, JJM)
}

// Itemized cost lines layered on top of the bill rate (InternalRosterEntry.hourlyRate).
// The malpractice case: type=MALPRACTICE, paidBy=FACILITY, reimbursable=true.
enum CostComponentType {
  MALPRACTICE
  AGENCY_MARGIN
  STIPEND
  TRAVEL
  OTHER
}

enum IncentiveShiftStatus {
  OPEN
  FILLED
  EXPIRED
  ESCALATED
}

enum AvailabilityWindowStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum InsightType {
  LATE_SCHEDULING
  PROVIDER_MIX
  DEMAND_FORECAST
  UTILIZATION
}

enum CalculatorType {
  AGENCY_REPLACEMENT
  EFFICIENCY
}

enum LeadFollowUpStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  CUSTOMER
  NOT_INTERESTED
}

// ── SNAP Credentialing enums ──────────────────────────────────────────────────

enum CredentialPermission {
  COORDINATOR
  DEPT_HEAD
  BILLING
}

enum CredentialType {
  STATE_LICENSE
  DEA_CERTIFICATE
  MA_CS_LICENSE
  BOARD_CERTIFICATION
  MALPRACTICE_INSURANCE
  MALPRACTICE_HISTORY
  ACLS_CERTIFICATION
  BLS_CERTIFICATION
  EDUCATION_HISTORY
  HOSPITAL_PRIVILEGES
  WORK_HISTORY
  NPDB_AUTHORIZATION
  CV
}

enum CredStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  MISSING
  PENDING
}

enum RosterMatchStatus {
  LINKED
  INVITED
  NOT_INVITED
}

// ── Existing models ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  role      UserRole @default(PROVIDER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerProfile            ProviderProfile?
  facilityMemberships        FacilityUser[]
  scheduleBuildRunsTriggered ScheduleBuildRun[]
  facilityInvitesSent        FacilityInvite[]   @relation("FacilityInviteSentBy")
  facilityInvitesClaimed     FacilityInvite[]   @relation("FacilityInviteClaimedBy")
  passwordResets             PasswordReset[]
  agreementAcceptances       AgreementAcceptance[]
  benchmarkConsents          BenchmarkConsent[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProviderProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName             String?
  lastName              String?
  specialty             Specialty?
  additionalSpecialties Specialty[]
  yearsExperience       Int?
  city                  String?
  zipCode               String?
  state                 String      @default("MA")
  lat                   Float?
  lng                   Float?
  photoUrl              String?

  pin       String?
  npiNumber String? @unique

  credentialed          Boolean   @default(false)
  maLicenseNumber       String?
  maLicenseExpiry       DateTime?
  maLicenseAcknowledged Boolean   @default(false)

  personalStatement    String?
  equipmentPreferences String?
  caseMixExperience    String?

  vipPoints   Int       @default(0)
  vipStatus   Boolean   @default(false)
  vipEarnedAt DateTime?
  lastLoginAt DateTime?

  notifPreference NotifPreference @default(IMMEDIATE)
  notifSurge      Boolean         @default(true)
  expoPushToken   String?

  profileCompletePct Int @default(0)

  applications            ShiftApplication[]
  bookings                ShiftBooking[]
  completions             ShiftCompletion[]
  availability            ProviderAvailability[]
  ratingsReceived         ProviderRating[]
  facilityRatings         FacilityRating[]
  preferredAt             PreferredProvider[]
  vipLogs                 VIPPointsLog[]
  sentMessages            Message[]
  availabilitySubmissions AvailabilitySubmission[]
  credentials             ProviderCredential[]
  rosterEntries           FacilityRosterEntry[]
  notifications           Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Facility {
  id                     String        @id @default(cuid())
  name                   String
  facilityType           FacilityType?
  address                String?
  zipCode                String?
  state                  String        @default("MA")
  lat                    Float?
  lng                    Float?
  photoUrls              String[]
  description            String?
  caseMix                String?
  parking                String?
  whatToBring            String?
  profileScore           Int           @default(0)
  snapMode               SnapMode      @default(BOTH)
  // Pay-period schedule: set once, then payroll periods auto-generate from it
  // so a coordinator picks "Jun 6 – Jun 20" instead of typing the span each run.
  payAnchorDate          String? // "YYYY-MM-DD" — start date of any one known pay period
  payFrequency           String        @default("BIWEEKLY") // WEEKLY | BIWEEKLY
  // Industry-standard fully-loaded cost to staff one anesthetizing location
  // for one day ($/room/day), entered by the coordinator. Used as the
  // "old manual process" baseline the SNAP-built schedule is compared against
  // on the Schedule Builder (baseline = rate x room-days covered).
  industryRoomRatePerDay Float?
  // Out-List Builder rule set (admin-configured). JSON blob:
  //   { lateSites: string[], lateSiteNoCloseAdjacent: bool,
  //     closerFirstOutNextDay: bool, noBackToBackClosing: bool }
  // Drives the one-click "auto-build out lists" for a week/month. null =
  // use defaults. See services/outListRules.js.
  outListRules           Json?
  isDemo                 Boolean       @default(false)
  // Per-location StaffIQ config, keyed by the upload's facilityLocation string
  // (matched by normalized substring). Shape per location:
  //   { "excludeFromSavings": bool,   // site reimbursed per provider — staffing
  //                                   // mix carries no cost to this practice, so
  //                                   // it is excluded from waste/score/savings
  //     "billingModel": "per_provider_reimbursed" | "cost",
  //     "reason": "...",              // shown wherever the exclusion is reported
  //     "supervisionRatio": 3|4 }     // overrides coverage-template ratio
  staffiqLocationConfig  Json?

  invoices            SnapInvoice[]
  users               FacilityUser[]
  subscription        FacilitySubscription?
  shifts              Shift[]
  preferredProviders  PreferredProvider[]
  providerRatings     ProviderRating[]
  facilityRatings     FacilityRating[]
  messages            Message[]
  rosterEntries       InternalRosterEntry[]
  availabilityWindows AvailabilityWindow[]
  scheduleDays        ScheduleDay[]
  schedulingUploads   SchedulingUpload[]
  scheduleFeedback    ScheduleFeedback[]
  schedulingRecords   SchedulingRecord[]
  staffiqInsights     StaffIQInsight[]
  incentiveShifts     InternalIncentiveShift[]
  staffiqInputs       StaffIQInput[]
  staffiqScoreHistory StaffIQScoreHistory[]
  staffingProfile     FacilityStaffingProfile?
  staffiqOutcomes     StaffIQOutcome[]
  credentialUsers     CredentialUser[]
  credRosterEntries   FacilityRosterEntry[]
  coverageTemplates   CoverageTemplate[]
  holidays            FacilityHoliday[]
  scheduleBuildRuns   ScheduleBuildRun[]
  automationEvents    AutomationEvent[]
  providerLocations   ProviderLocation[]
  siteRates           FacilitySiteRate[]
  roiBaseline         FacilityRoiBaseline?
  roiSnapshots        FacilityRoiSnapshot[]
  facilityInvites     FacilityInvite[]
  agreementAcceptances AgreementAcceptance[]
  benchmarkConsents   BenchmarkConsent[]
  locationContacts    FacilityLocationContact[]
  roomCountRequests   RoomCountRequest[]
  scheduleRequests    ScheduleRequest[]
  featureFlags        FacilityFeatureFlag[]
  payrollTemplates    PayrollTemplateConfig[]
  payrollRuns         PayrollRun[]
  marketplaceFees     MarketplaceFeeLedger[]
  ptoWindows          PtoWindow[]
  // EOR (Phase 0). selfEmployer = this facility's own-W2 Employer row;
  // employerLinks = external agencies (APNE, JJM) allowed to staff it.
  selfEmployer        Employer?                @relation("FacilitySelfEmployer")
  employerLinks       EmployerFacilityLink[]
  hourEntries         ProviderHourEntry[]
  locations           FacilityLocation[]
  availabilityRequests AvailabilityRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Facility coordinator/admin invite — the "front door" for new customers.
// Replaces the broken /auth/facility/register self-serve flow with a SNAP-
// admin-initiated invite. Mirrors the ProviderInvite pattern on the cred
// backend: admin sends invite, recipient receives email with a tokenized
// claim link, recipient sets password → account is created + linked to the
// pre-existing Facility in a single transaction. No orphan rows, no
// "your facility" null-fallback states.
//
// See snap-applications/capa-pilot/facility-invite-spec.md for the full
// design + UX trade-offs. Locked 2026-06-09.
model FacilityInvite {
  id               String    @id @default(cuid())
  facilityId       String
  facility         Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  // The email we sent the invite to. Lowercased + trimmed at send time.
  email            String
  // Role the invited user will have within the facility once they claim.
  // ADMIN / COORDINATOR / VIEWER — string so it's flexible without a new enum.
  facilityRole     String
  // sha256 of the raw token. We never store the raw token itself, so a DB
  // leak doesn't compromise active invites.
  tokenHash        String    @unique
  // First 8 chars of the raw token, for logs/debug only. Never enough to
  // reconstruct, but enough to correlate "I sent this invite" with logs.
  rawTokenPrefix   String?
  expiresAt        DateTime
  // The admin User who sent the invite. Captured at send-time so we can
  // surface "Matt Haverkamp invited you" in the email + claim page even
  // if the admin's account is renamed/deleted later.
  invitedByAdminId String?
  invitedByAdmin   User?     @relation("FacilityInviteSentBy", fields: [invitedByAdminId], references: [id])
  invitedByName    String?
  // Set when the recipient successfully claims the invite. nullable means
  // "still pending."
  claimedAt        DateTime?
  claimedByUserId  String?
  claimedByUser    User?     @relation("FacilityInviteClaimedBy", fields: [claimedByUserId], references: [id])
  createdAt        DateTime  @default(now())

  @@index([facilityId])
  @@index([email])
}

// Per-facility ROI baseline — the "before SNAP" numbers that drive every
// savings calculation. One row per Facility. Admin-editable. Fields mirror
// the CAPA-pilot ROI tracker constants so existing customers + prospects
// share one math model. Reasonable defaults pre-populate at upsert time.
model FacilityRoiBaseline {
  id                      String   @id @default(cuid())
  facilityId              String   @unique
  facility                Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  // Workforce + headline cost
  providerCount           Int      @default(83)
  monthlyProviderCost     Float    @default(1150000)
  providerHourlyRate      Float    @default(295)
  // Backup-staffing baseline
  backupPremium           Float    @default(0.15) // 15% premium for backup
  backupShiftsPerDay      Float    @default(5)
  shiftHours              Float    @default(8)
  annualBackupStaffing    Float    @default(287500)
  // Admin overhead baseline
  adminSchedulingStaff    Float    @default(2)
  adminSchedulingHours    Float    @default(25) // per-staff weekly
  adminSchedulingRate     Float    @default(100)
  credentialingStaff      Float    @default(1)
  credentialingHours      Float    @default(20) // per-staff weekly
  credentialingRate       Float    @default(75)
  // KPI baselines
  credentialingTurnaround Int      @default(21) // days
  schedulingGapRate       Float    @default(18) // %
  providerSatisfaction    Float    @default(6.2) // /10
  // Free-form notes (e.g. "Numbers from CAPA July 2026 sourcing call")
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// Per-facility, per-month ROI snapshot. Captures the actuals the admin
// would otherwise overwrite. Drives the "month 3 vs month 1" comparison
// during renewals + the SNAP-wide rollup. `month` is the first day of the
// snapshot month (YYYY-MM-01 UTC) so a (facilityId, month) unique key
// works. Some fields can be auto-pulled from live data — `autoPulled`
// records which ones so the UI can flag them.
model FacilityRoiSnapshot {
  id                      String   @id @default(cuid())
  facilityId              String
  facility                Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  month                   DateTime @db.Date
  backupShiftsPerDay      Float?
  adminSchedulingHours    Float?
  credentialingHours      Float?
  credentialingTurnaround Int?
  schedulingGapRate       Float?
  providerSatisfaction    Float?
  // Which of the above were auto-pulled vs entered. Free-form JSON keyed
  // by metric name → boolean. UI uses this to mark fields as "(auto)".
  autoPulled              Json?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([facilityId, month])
  @@index([facilityId, month])
}

// Per-site override of Facility.industryRoomRatePerDay. Customers like CAPA
// staff multiple ASCs at meaningfully different baselines (Matt's ASC at
// $3,450, others at different numbers). When a site has a row here, the
// cost panel + summary use it. When it doesn't, it falls back to the
// facility-level default. siteName matches the location strings used on
// ScheduleDay / coverage templates verbatim (e.g. "Atrius Kenmore").
model FacilitySiteRate {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  siteName   String
  ratePerDay Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([facilityId, siteName])
}

model FacilityUser {
  id           String   @id @default(cuid())
  userId       String
  facilityId   String
  facilityRole String   @default("SCHEDULER")
  user         User     @relation(fields: [userId], references: [id])
  facility     Facility @relation(fields: [facilityId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([userId, facilityId])
}

// ── SNAP Platform Invoices ────────────────────────────────────────────────────
// Pre-Stripe manual invoicing. Admin generates + emails a PDF invoice to any
// facility. Supports full pricing, Founder's pricing, and timed promo upgrades.
model SnapInvoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique // e.g. SNAP-2026-001
  facilityId    String?
  facility      Facility? @relation(fields: [facilityId], references: [id])

  // Bill-to (denormalized so invoice is immutable even if facility changes)
  billingName     String
  billingEmail    String
  billingAddress  String?
  billingCcEmails String  @default("") // comma-separated; always included on every send
  paymentLink     String? // e.g. Stripe payment link URL, shown as button in invoice email

  // Line items JSON array: { description, detail, listPrice, discount, discountLabel, amount }
  lineItems     Json

  // Totals
  listTotal     Float   // sum of listPrice (what they would pay at full rate)
  discountTotal Float   @default(0)
  amountDue     Float   // listTotal - discountTotal

  // Promo / Founder's config — stored for audit trail + auto-expiry reminders
  discountType   String?  // 'FOUNDER' | 'PROMO_1MO' | 'PROMO_2MO' | 'PROMO_3MO' | 'PROMO_6MO'
  promoFeatures  String?  // e.g. 'SNAP Complete' — what they get free during promo
  promoExpiresAt DateTime?

  status     String   @default("DRAFT") // DRAFT | SENT | PAID | VOID
  invoiceDate DateTime @default(now())
  dueDate    DateTime
  sentAt     DateTime?
  paidAt     DateTime?
  notes      String?

  // Recurring billing
  billingCycle  String    @default("ONCE") // ONCE | MONTHLY
  nextRecurAt   DateTime? // next auto-send date when billingCycle = MONTHLY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facilityId])
  @@index([status])
  @@index([billingCycle, nextRecurAt])
}

model FacilitySubscription {
  id                    String           @id @default(cuid())
  facilityId            String           @unique
  facility              Facility         @relation(fields: [facilityId], references: [id])
  tier                  SubscriptionTier @default(BASIC)
  status                String           @default("ACTIVE")
  shiftsPostedThisMonth Int              @default(0)
  monthResetAt          DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Shift {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id])

  specialty       Specialty
  date            DateTime
  startTime       String
  durationHours   Float
  baseRate        Float
  currentRate     Float
  surgeEnabled    Boolean     @default(false)
  surgeMultiplier Float       @default(1.0)
  featured        Boolean     @default(false)
  status          ShiftStatus @default(DEPOSIT_PENDING)

  preferredAccessOnly Boolean   @default(false)
  preferredWindowEnds DateTime?

  // When a facility posts a recurring/bulk series, every shift in the batch
  // shares this id so the series can be confirmed/managed together. null = a
  // one-off single post. See services/recurrence.js + POST /shifts/series.
  recurrenceGroupId String?

  expiresAt      DateTime?
  currentViewers Int       @default(0)

  estimatedTotal     Float?
  depositAmount      Float?
  depositConfirmed   Boolean   @default(false)
  depositConfirmedAt DateTime?

  platformFeePercent Float         @default(10.0)
  platformFeeAmount  Float?
  paymentStatus      PaymentStatus @default(PENDING)
  paymentSettledAt   DateTime?

  applications ShiftApplication[]
  booking      ShiftBooking?
  completions  ShiftCompletion[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recurrenceGroupId])
}

model ShiftApplication {
  id         String            @id @default(cuid())
  shiftId    String
  providerId String
  shift      Shift             @relation(fields: [shiftId], references: [id])
  provider   ProviderProfile   @relation(fields: [providerId], references: [id])
  status     ApplicationStatus @default(PENDING)
  appliedAt  DateTime          @default(now())
  reviewedAt DateTime?

  @@unique([shiftId, providerId])
}

model ShiftBooking {
  id         String          @id @default(cuid())
  shiftId    String          @unique
  providerId String
  shift      Shift           @relation(fields: [shiftId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  providerHourlyRate Float?
  shiftDurationHours Float?
  totalShiftValue    Float?
  platformFeePercent Float?
  platformFeeAmount  Float?
  facilityTier       SubscriptionTier?

  paymentStatus PaymentStatus @default(PENDING)
  confirmedAt   DateTime      @default(now())
  completedAt   DateTime?
  cancelledAt   DateTime?

  providerRating ProviderRating?
  facilityRating FacilityRating?
  completion     ShiftCompletion?
  feeLedger      MarketplaceFeeLedger?

  createdAt DateTime @default(now())
}

model ShiftCompletion {
  id         String          @id @default(cuid())
  shiftId    String
  bookingId  String          @unique
  providerId String
  shift      Shift           @relation(fields: [shiftId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  providerConfirmed   Boolean   @default(false)
  providerHours       Float?
  providerNotes       String?
  providerConfirmedAt DateTime?

  facilityConfirmed   Boolean   @default(false)
  facilityHours       Float?
  facilityNotes       String?
  facilityConfirmedAt DateTime?

  disputed          Boolean   @default(false)
  disputeResolvedAt DateTime?
  disputeNotes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderAvailability {
  id         String          @id @default(cuid())
  providerId String
  date       DateTime        @db.Date
  available  Boolean
  // Free-text note the provider attaches to a specific date — e.g.
  // "can work after 10am", "Natick only this day". Surfaced to the
  // coordinator in the schedule-builder day editor so it informs
  // assignments. Task #20.
  note       String?
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())

  @@unique([providerId, date])
}

model ProviderRating {
  id         String          @id @default(cuid())
  facilityId String
  providerId String
  bookingId  String          @unique
  stars      Int
  notes      String?
  facility   Facility        @relation(fields: [facilityId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  createdAt  DateTime        @default(now())
}

model FacilityRating {
  id         String          @id @default(cuid())
  providerId String
  facilityId String
  bookingId  String          @unique
  stars      Int
  notes      String?
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  facility   Facility        @relation(fields: [facilityId], references: [id])
  booking    ShiftBooking    @relation(fields: [bookingId], references: [id])
  createdAt  DateTime        @default(now())
}

model PreferredProvider {
  id         String          @id @default(cuid())
  facilityId String
  providerId String
  facility   Facility        @relation(fields: [facilityId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  addedAt    DateTime        @default(now())

  @@unique([facilityId, providerId])
}

model VIPPointsLog {
  id         String          @id @default(cuid())
  providerId String
  points     Int
  reason     VIPReason
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  createdAt  DateTime        @default(now())
}

model Message {
  id         String          @id @default(cuid())
  shiftId    String
  facilityId String
  senderId   String
  body       String
  flagged    Boolean         @default(false)
  readAt     DateTime?
  shift      Shift           @relation(fields: [shiftId], references: [id])
  facility   Facility        @relation(fields: [facilityId], references: [id])
  sender     ProviderProfile @relation(fields: [senderId], references: [id])
  createdAt  DateTime        @default(now())
}

// ── SNAP Shifts models ────────────────────────────────────────────────────────

model InternalRosterEntry {
  id                        String              @id @default(cuid())
  facilityId                String
  facility                  Facility            @relation(fields: [facilityId], references: [id])
  providerName              String
  // Nullable so non-clinical roster members (back-office staff, billers)
  // can be on the roster for payroll without a clinical specialty. Clinical
  // scheduling explicitly excludes rows where providerType is null OR
  // isNonClinical is true (see scheduleBuilder.js + isNonClinical below).
  providerType              Specialty?
  employmentCategory        EmploymentCategory?
  // True for back-office / non-clinical staff who belong on the roster for
  // payroll purposes but are never scheduled into ORs and don't need an NPI.
  isNonClinical             Boolean             @default(false)
  // True when the coordinator has explicitly marked this person as not
  // needing an NPI (back-office staff, or a provider they'll handle out of
  // band). Exempt rows are excluded from the NPI review queue. Auto-set true
  // for non-clinical imports.
  npiExempt                 Boolean             @default(false)
  snapAccountEmail          String?
  phoneNumber               String?
  // NPI (National Provider Identifier) — primary key for matching this
  // roster entry to an existing ProviderProfile across the marketplace.
  // 10-digit string; unique-per-facility because the same provider could
  // (rarely) be on two practices' rosters as a locum.
  npi                       String?
  // Customer-internal provider code (e.g. CAPA's "Initials" field). Used
  // as the join key when a multi-sheet xlsx import bundles identity,
  // payroll, and per-location credentialing across separate tabs. NOT a
  // SNAP-wide identifier — only meaningful within ONE facility's roster.
  rosterCode                String?
  // External payroll-system identifier (Gusto / ADP / Paychex / etc).
  // Pass-through field so the SNAP Payroll tab can export weekly
  // summaries that link back to the customer's payroll provider rows.
  payrollSystemId           String?
  // Secret token for the provider's personal iCal subscription URL
  // (/api/schedule/ical/:rosterEntryId/:icalToken.ics). Generated on first
  // request, regenerated when the provider rotates the URL. Anyone with the
  // URL can read this provider's schedule, so treat it like a password.
  icalToken                 String?
  // Who employs / staffs this provider into the facility. For CAPA this is
  // typically one of: "APNE" (Matt's anesthesia practice — staffs CAPA),
  // "CAPA" (CAPA-W2-employed staff), "JJM" (contracted group). NOTE: `hourlyRate`
  // is the PAY rate (what the provider earns, drives payroll); what the facility
  // pays the employer all-in lives in `allInCostPerHour`. Free-form so customers
  // don't have to
  // wait for an enum edit when they onboard a new staffing group.
  // PHASE 0: kept as a denormalized mirror of Employer.name during migration;
  // employerId below is the new source of truth. See eor-model-spec.md.
  employer                  String?
  // EOR link (Phase 0). Who pays this provider — resolves to a FACILITY_SELF
  // Employer for CAPA's own W-2 staff, or a STAFFING_AGENCY (APNE) for 1099s.
  employerId                String?
  employerRef               Employer?           @relation(fields: [employerId], references: [id])
  // 1099 contractors may be paid under a business name (LLC/EIN) rather than
  // their personal name. `businessName` holds it; `useBusinessNameForPayroll`,
  // when true, makes the Payroll Builder export the business name (and blank the
  // first/last name columns) for THIS provider — PAYROLL ONLY. Everywhere else
  // in SNAP (marketplace, shifts, credentialing) the person is addressed by
  // their actual name.
  businessName              String?
  useBusinessNameForPayroll Boolean             @default(false)
  // Payee identity for the (future) payroll-feed export — mirrors the APNE
  // payroll sheet's contractor_type/ein columns. "Business" payees bill under an
  // LLC/EIN; "Individual" payees under their name. SSN is deliberately NOT stored
  // here — full SSNs stay in the payroll processor until the feed generator is
  // built (then encrypted-at-rest or last-4 only). See eor-model-spec.md.
  payeeType                 String? // "Business" | "Individual"
  ein                       String?
  // Dual employment: same person is W-2 at one employer AND 1099 at another
  // (e.g. W-2 at CAPA + 1099 at APNE). When true, the W-2 side uses annualRate
  // (salary) and w2Employer; the 1099 side uses contractorPayRate + the payee
  // identity above (payeeType/businessName/ein) + allInCostPerHour (the rate the
  // CAPA-site 1099 hours are billed at) + contractorEmployer. hourlyRate stays
  // free for W-2-hourly staff so the dual 1099 rate never pollutes W-2 payroll.
  // See eor-model-spec.md (site-ownership + dual-employment section).
  dualEmployment            Boolean             @default(false)
  w2Employer                String? // who pays the W-2 salary (e.g. "CAPA")
  contractorEmployer        String? // who pays the 1099 (e.g. "APNE")
  contractorPayRate         Float? // 1099 pay rate for a DUAL provider
  // Tax-status flag, orthogonal to employmentCategory. true = 1099 contractor,
  // false = W-2 employee, null = unknown. Surfaced on the roster card so the
  // coordinator can see "1099 · FT" at a glance for cost attribution.
  is1099                    Boolean?
  // Hours-status flag, orthogonal to employmentCategory. true = full-time,
  // false = part-time, null = unknown. The scheduler still keys off
  // employmentCategory (FULL_TIME/PER_DIEM/LOCUMS); this is descriptive only.
  isFullTime                Boolean?
  // Placement priority ladder for the Schedule Builder. Lower number = filled
  // first. 1=Full-time (W-2), 2=Part-time, 3=Per Diem 1, 4=Per Diem 2, 5=Locum.
  // Committed core (full/part-time) have set schedules and sit in the PTO
  // calendar, so they're placed first around their PTO; per-diems then locums
  // fill the remaining rooms in tier order. This is a DOMINANT sort key in the
  // auto-builder (scheduleBuilder.js) — it overrides cost/quality across tiers,
  // while cost/quality/requests still break ties WITHIN a tier. null = derive a
  // sensible tier from employmentCategory (FULL_TIME→1, PER_DIEM→3, LOCUMS→5).
  placementTier             Int?
  // NPPES lookup state. Set when the import couldn't auto-attach an NPI
  // (multiple matches or zero matches in NPPES). The disambiguation UI
  // surfaces these for coordinator resolution. Cleared once npi is set.
  npiLookupStatus           String? // 'NEEDS_DISAMBIGUATION' | 'NO_MATCH' | 'INVALID_NAME'
  npiLookupCandidates       Json? // array of NPPES match objects for the disambiguation UI
  licenseNumber             String?
  licenseExpiration         DateTime?
  notes                     String?
  snapAccountLinked         Boolean             @default(false)
  linkedProviderId          String?
  // Provider schedule access. A linked provider can view this facility's daily
  // board in their app BY DEFAULT; the facility revokes per provider by setting
  // scheduleAccessRevoked. v1.1: if access is revoked, the provider can REQUEST
  // it back (scheduleAccessRequested=true) → the facility sees the request and
  // grants (un-revokes). See eor-model-spec.md / provider↔facility schedule access.
  scheduleAccessRevoked     Boolean             @default(false)
  scheduleAccessRequested   Boolean             @default(false)
  inviteSentAt              DateTime?
  // Credentialing-invite lifecycle, distinct from snapAccountLinked (which is
  // a *marketplace* account). Flips NOT_INVITED → INVITED when a coordinator
  // sends a credentialing invite; CLAIMED/COMPLETED are synced back from the
  // passport bridge (a live grant means the provider claimed + consented).
  credentialingStatus       String              @default("NOT_INVITED") // NOT_INVITED | INVITED | CLAIMED | COMPLETED
  // True for providers already credentialed via the manual/legacy process.
  // Excluded from "Invite all" — their SNAP credentialing is deferred to their
  // next license renewal so we don't disrupt active credentials. Explicitly
  // selecting them in the invite modal overrides this.
  externallyCredentialed    Boolean             @default(false)
  createdAt                 DateTime            @default(now())

  // Employment-specific preference fields
  fteHours             Float? // FULL_TIME: hours per week
  annualRate           Float? // FULL_TIME: annual base salary
  hourlyRate           Float? // PER_DIEM / LOCUMS: the PAY rate — what the provider/employee is actually paid. Drives the Payroll Builder export.
  // "All-in cost" — the facility's true fully-loaded cost PER HOUR for this
  // provider. Generic + optional (blank = not tracked): for an agency-staffed
  // 1099 it's the bill rate the facility owes the agency (pay + malpractice +
  // margin); for the facility's own W-2 staff it's the loaded cost (wage +
  // taxes/benefits). The gap (allInCostPerHour - hourlyRate) x hours is the
  // agency markup / reimbursement the facility owes. Feeds the EOR cost rollup
  // (services/eorCost.js) and the one-click agency-invoice calc.
  allInCostPerHour     Float?
  preferredShiftLength String? // "8hr" | "10hr" | "12hr" | "none"
  preferredDays        Json? // String[] e.g. ["Mon","Tue","Wed"]
  locationRankings     Json? // Array of location name strings (ranked)
  maxShiftsPerMonth    Int? // PER_DIEM: cap on shifts
  contractStart        DateTime? // LOCUMS: contract start
  contractEnd          DateTime? // LOCUMS: contract end

  // Reliability score 0.0-1.0 used by Schedule Builder v2 quality algorithm.
  // Computed by a future background job from ShiftCompletion history (no-shows,
  // late arrivals, cancellations). null = not yet computed; algorithm treats
  // null as the practice's average (currently 0.85 as a sensible default).
  reliabilityScore Float?
  // Admin-assigned quality score 1–5 (null = unrated). Set by the facility
  // coordinator to reward proven excellence. Feeds the HIGHEST_QUALITY and
  // HYBRID schedule builder modes as a 20% weight alongside reliability.
  adminQualityScore Int?

  // ── PTO (paid time off) — see docs / pto-builder-spec ───────────────────────
  // Annual PTO-day allotment shown on the profile card ("PTO days annual").
  // null = use the facility/system default (DEFAULT_PTO_DAYS_ANNUAL). Admin can
  // override per provider. "Granted" and "used so far" are NOT stored — they're
  // derived from source='PTO' RosterAvailability weekday rows for the year.
  ptoDaysAnnual Int?
  // PTO eligibility. null = derive from employment (W-2 i.e. is1099=false, OR
  // full-time); true/false = explicit admin override. Per the locked spec, all
  // full-time/W-2 staff are eligible by default; per-diems only when flagged.
  ptoEligible   Boolean?
  // Manual seniority rank for the future PTO Builder tie-break (1 = most
  // senior). Unused by Feature A; added now so the profile card holds it.
  seniorityRank Int?

  scheduleAssignments ScheduleAssignment[]
  incentiveResponses  InternalIncentiveShiftResponse[]
  scheduleFeedback    ScheduleFeedback[]
  locations           ProviderLocation[]
  timeOff             RosterTimeOff[]
  availability        RosterAvailability[]
  scheduleRequests    ScheduleRequest[]
  rateHistory         RosterRateHistory[]
  payrollLineItems    PayrollRunProvider[]
  ptoBids              PtoBid[]
  ptoAllocations       PtoAllocation[]
  costComponents       AssignmentCostComponent[] // EOR pass-throughs (Phase 0)
  hourEntries          ProviderHourEntry[]
  availabilityRequests AvailabilityRequest[]

  @@index([rosterCode])
  @@index([facilityId, npi])
}

// Provider time off / PTO. Keyed on the roster entry (not a SNAP
// ProviderProfile) so it works for every roster member — including the
// many CAPA providers without a linked SNAP account. The Schedule Builder
// HARD-excludes anyone with time off covering a date (never auto-assigns
// them), and the day editor grays them out. Inclusive date range
// [startDate, endDate]. v1 is coordinator-entered; provider self-request +
// approval workflow is v1.1.
model RosterTimeOff {
  id                String              @id @default(cuid())
  rosterEntryId     String
  rosterEntry       InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  facilityId        String
  startDate         DateTime            @db.Date
  endDate           DateTime            @db.Date
  reason            String?
  // When this time-off was materialized from a Tier-1 DAY_OFF ScheduleRequest,
  // links back to it so re-triaging (downgrade/decline) can clean it up. Plain
  // scalar (no relation) — only the builder/triage code reads it. null =
  // coordinator-entered time off, not request-managed.
  scheduleRequestId String?             @unique
  createdAt         DateTime            @default(now())

  @@index([facilityId, startDate, endDate])
  @@index([rosterEntryId])
}

// Per-date availability override, keyed on the roster entry (not a SNAP
// ProviderProfile) so it works for every roster member — including providers
// not yet on the app (the early-onboarding case). One row = "on this date,
// this person IS / IS NOT available", with an optional note.
//
// How the Schedule Builder resolves effective availability for (entry, date):
//   1. ADMIN RosterAvailability row  → authoritative (wins over everything)
//   2. RosterTimeOff range covering the date → unavailable (admin PTO)
//   3. PROVIDER RosterAvailability / app-submitted ProviderAvailability → use it
//   4. Default by employmentCategory: FULL_TIME = available; PER_DIEM / LOCUMS
//      = UNAVAILABLE unless explicitly marked available.
// So full-time staff are exception-based (mark PTO), and per-diems are opt-in
// (must be marked available by the provider or the admin).
model RosterAvailability {
  id            String              @id @default(cuid())
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  facilityId    String
  date          DateTime            @db.Date
  available     Boolean
  note          String?
  source        String              @default("ADMIN") // ADMIN | PROVIDER
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([rosterEntryId, date])
  @@index([facilityId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// ProviderLocation — per-provider × per-location credentialing matrix.
//
// One row per (rosterEntry, facilityName) pair. Binary: presence of the row
// means "this provider is credentialed to work at this location." Used by:
//   - Schedule Builder v2 eligibility filter (only assign providers to rooms
//     at locations they're credentialed at)
//   - Per-facility coordinator views ("show me everyone at Kenmore")
//   - Future: non-hospital facility wedge (Task #17 — ASCs/clinics declare
//     lighter required credential sets per location)
//
// facilityName is the raw string from the customer's source data (e.g. CAPA's
// "Facility 1..41" sheet cell values). facilityId is an optional FK to a
// Facility row if the name happens to match an existing facility. Most
// customer-internal location names will NOT match the marketplace Facility
// table (they're CAPA's own surgery centers), so facilityId stays null.
// ─────────────────────────────────────────────────────────────────────────────

model ProviderLocation {
  id            String              @id @default(cuid())
  rosterEntryId String
  rosterEntry   InternalRosterEntry @relation(fields: [rosterEntryId], references: [id], onDelete: Cascade)
  // Raw location name from customer's source (e.g. "Atrius Kenmore",
  // "Shields Natick"). Normalization across spelling variants is deferred
  // to a follow-up — exact-match dedupe for v1.
  facilityName  String
  // Optional FK to a Facility row when the name matches one on the
  // marketplace side. Stays null for customer-internal locations that
  // don't exist as marketplace Facility rows.
  facilityId    String?
  facility      Facility?           @relation(fields: [facilityId], references: [id])
  // Share (0-100) of this provider's shifts that should fall at this site.
  // Feeds StaffIQ scoring so providers are favored for their primary sites.
  // Null = credentialed but no share preference set.
  shiftSharePct Float?
  createdAt     DateTime            @default(now())

  @@unique([rosterEntryId, facilityName])
  @@index([facilityName])
}

model ScheduleFeedback {
  id               String              @id @default(cuid())
  facilityId       String
  facility         Facility            @relation(fields: [facilityId], references: [id])
  rosterId         String
  rosterEntry      InternalRosterEntry @relation(fields: [rosterId], references: [id])
  shiftDate        DateTime            @db.Date
  facilityLocation String
  wasSuggested     Boolean
  suggestionRank   Int?
  wasSelected      Boolean
  shiftCompleted   Boolean             @default(false)
  createdAt        DateTime            @default(now())
}

model AvailabilityWindow {
  id         String                   @id @default(cuid())
  facilityId String
  facility   Facility                 @relation(fields: [facilityId], references: [id])
  windowName String
  openDate   DateTime
  closeDate  DateTime
  message    String?
  notifyAll  Boolean                  @default(true)
  status     AvailabilityWindowStatus @default(DRAFT)
  createdAt  DateTime                 @default(now())

  submissions AvailabilitySubmission[]
}

model AvailabilitySubmission {
  id          String             @id @default(cuid())
  windowId    String
  providerId  String
  facilityId  String
  window      AvailabilityWindow @relation(fields: [windowId], references: [id])
  provider    ProviderProfile    @relation(fields: [providerId], references: [id])
  submittedAt DateTime           @default(now())

  @@unique([windowId, providerId])
}

model ScheduleDay {
  id                 String    @id @default(cuid())
  facilityId         String
  date               DateTime  @db.Date
  location           String
  roomsRequired      Int       @default(1)
  // Coverage model copied from the template at generation time. null =
  // MD-only; 3 = team 1:3; 4 = team 1:4. See CoverageTemplateDay.
  supervisionRatio   Int?
  publishedAt        DateTime?
  // Out-List Builder: when the day's release order ("who leaves first … who
  // closes") was finalized for the on-site floor runner. null = not yet set.
  // Layered on AFTER publish — it never gates publishing. The order itself
  // lives on ScheduleAssignment.outRank.
  outListPublishedAt DateTime?
  facility           Facility  @relation(fields: [facilityId], references: [id])

  assignments ScheduleAssignment[]

  @@unique([facilityId, date, location])
}

model ScheduleAssignment {
  id            String               @id @default(cuid())
  scheduleDayId String
  scheduleDay   ScheduleDay          @relation(fields: [scheduleDayId], references: [id])
  roomNumber    Int
  rosterId      String?
  rosterEntry   InternalRosterEntry? @relation(fields: [rosterId], references: [id])
  facilityId    String
  // Care-team role (Task #21 Phase B). null = legacy/role-agnostic room;
  // CRNA_ROOM / SOLO_MD_ROOM = a real OR room; SUPERVISING_MD = an
  // anesthesiologist supervising CRNA rooms (stored at roomNumber >= 900).
  role          String?
  // Out-List Builder: release order for the day (1 = leaves first … highest =
  // closes the facility). Scoped to the assignment's ScheduleDay (per site,
  // per date). null = not yet ranked. Only staffed slots (rosterId != null)
  // are ranked. See GET/PUT /schedule/days/:dayId/out-list.
  outRank       Int?
  createdAt     DateTime             @default(now())

  costComponents AssignmentCostComponent[] // EOR one-off pass-throughs (Phase 0)

  @@unique([scheduleDayId, roomNumber])
}

model SchedulingUpload {
  id             String    @id @default(cuid())
  facilityId     String
  facility       Facility  @relation(fields: [facilityId], references: [id])
  fileName       String
  rowCount       Int       @default(0)
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  status         String    @default("PROCESSED")
  uploadedAt     DateTime  @default(now())

  records SchedulingRecord[]
}

model SchedulingRecord {
  id               String            @id @default(cuid())
  facilityId       String
  facility         Facility          @relation(fields: [facilityId], references: [id])
  providerName     String?
  providerType     String?
  shiftDate        DateTime?
  startTime        String?
  endTime          String?
  durationHours    Float?
  facilityLocation String?
  caseType         String?
  rate             Float?
  // Weekday index (0=Sun..6=Sat) as stated by the source schedule, when available.
  // Preferred over re-deriving from shiftDate so Friday detection stays correct
  // even for schedules from another year or spanning a year boundary.
  dayOfWeek        Int?
  // Roster-vs-agency tagging (benchmark metric 3: agency dependence). Matched
  // by name fingerprint against InternalRosterEntry at upload; null = not yet
  // matched (no provider name, or record predates tagging — backfilled on the
  // next StaffIQ analysis run).
  isAgency         Boolean?
  matchedRosterId  String?
  sourceUploadId   String?
  sourceUpload     SchedulingUpload? @relation(fields: [sourceUploadId], references: [id])
  createdAt        DateTime          @default(now())
}

model StaffIQInsight {
  id                   String      @id @default(cuid())
  facilityId           String
  facility             Facility    @relation(fields: [facilityId], references: [id])
  generatedAt          DateTime    @default(now())
  insightType          InsightType
  insightData          Json
  dollarImpactEstimate Float?
  dataPointsAnalyzed   Int?
  // Closed-loop feedback: coordinators confirm or reject each insight, which is
  // the labeled signal the learning layer uses to calibrate thresholds over time.
  status               String      @default("NEW") // NEW | ACCEPTED | DISMISSED | ACTIONED
  feedback             Json? // { reason, note, by, at }
  actionedAt           DateTime?
}

model InternalIncentiveShift {
  id                     String               @id @default(cuid())
  facilityId             String
  facility               Facility             @relation(fields: [facilityId], references: [id])
  shiftDate              DateTime
  startTime              String
  durationHours          Float
  facilityLocation       String
  incentiveRate          Float
  // Two shift types offered to the internal roster (Task #19):
  //   true  = INCENTIVE shift — premium rate above standard, the StaffIQ
  //           "incentivize N CRNAs, save $X" flow.
  //   false = AVAILABLE shift — open coverage at the standard rate, no premium.
  // incentiveRate holds the offered rate in both cases (premium vs standard);
  // the UI labels it based on this flag.
  isIncentive            Boolean              @default(true)
  providerTypeRequired   Specialty
  responseDeadline       DateTime
  status                 IncentiveShiftStatus @default(OPEN)
  escalatedToMarketplace Boolean              @default(false)
  escalationApprovedAt   DateTime?
  escalationApprovedBy   String?
  marketplaceShiftId     String?
  createdAt              DateTime             @default(now())

  responses InternalIncentiveShiftResponse[]
}

model InternalIncentiveShiftResponse {
  id          String                 @id @default(cuid())
  shiftId     String
  shift       InternalIncentiveShift @relation(fields: [shiftId], references: [id])
  rosterId    String
  rosterEntry InternalRosterEntry    @relation(fields: [rosterId], references: [id])
  accepted    Boolean
  respondedAt DateTime               @default(now())

  @@unique([shiftId, rosterId])
}

model StaffIQCalculatorResult {
  id              String         @id @default(cuid())
  calculatorType  CalculatorType
  facilityName    String?
  contactName     String?
  email           String?
  inputData       Json
  outputData      Json
  reportGenerated Boolean        @default(false)
  reportSent      Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

model Lead {
