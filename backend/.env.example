# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically by Railway when you add a PostgreSQL plugin.
# Copy the DATABASE_URL value from the Railway PostgreSQL service variables tab.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-hex-string

# ── Admin seed ────────────────────────────────────────────────────────────────
# These credentials are created on first boot if the admin user doesn't exist.
ADMIN_EMAIL=admin@snapmedical.com
ADMIN_PASSWORD=replace-with-strong-password

# ── SendGrid (transactional email) ────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@snapmedical.com

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+18669701509

# ── AWS S3 (facility photo uploads) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=snap-marketplace-uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Set AFTER you get your Railway web portal URL (Step 9 in DEPLOYMENT.md).
CORS_ORIGINS=https://your-web.up.railway.app

# ── Cross-app bridge → snap-credentialing ─────────────────────────────────────
# Base URL of the credentialing backend. Marketplace calls the credentialing
# API to drive signature requests and read passport state — never owning its
# own copy of credential data.
CREDENTIALING_API_URL=https://snap-credentialing-backend-production.up.railway.app
# Shared secret. Same value as CREDENTIALING_SERVICE_API_KEY on the
# credentialing side. Rotate by changing both env vars and redeploying both
# services together.
CREDENTIALING_API_KEY=replace-with-shared-secret

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT set this in the Railway dashboard.
NODE_ENV=production
